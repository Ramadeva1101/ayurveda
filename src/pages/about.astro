---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import FloatingWhatsApp from '../components/FloatingWhatsApp.astro';
import SectionDivider from '../components/SectionDivider.astro';
import ProfileCard from '../components/ProfileCard.astro';
---

<BaseLayout
  title="About Us"
  description="Meet the practitioners behind Ayurvedic Wellness House — Dr. Komang Sudarmi, Ayurvedic Physician, Researcher, and Educator, and her team of trained therapists."
>
  <Navbar />

  <main id="main-content">

    <!-- Page Header -->
    <section class="page-header section">
      <div class="container">
        <p class="page-eyebrow">About Us</p>
        <h1 class="page-title">The Practitioners Behind Ayurvedic Wellness House</h1>
      </div>
    </section>

    <SectionDivider variant="simple" />

    <!-- Dr. Komang — Large, Prominent Founder Profile -->
    <section class="founder section section--alt">
      <div class="container">
        <div class="founder-inner">
          <div class="founder-portrait">
            <div class="founder-portrait__image">
              <div class="img-placeholder">
                <svg class="img-placeholder__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                  <circle cx="8.5" cy="8.5" r="1.5"></circle>
                  <polyline points="21 15 16 10 5 21"></polyline>
                </svg>
                <span class="img-placeholder__label">[ dr-komang-portrait.webp — 800x1000px ]</span>
              </div>
            </div>
          </div>

          <div class="founder-bio">
            <h2 class="founder-name">Dr. Komang Sudarmi, BAMS., MS., PhD (Ayurveda)</h2>
            <p class="founder-role">Founder &amp; Chief Ayurvedic Physician</p>
            <div class="founder-divider" aria-hidden="true"></div>

            <!-- Stats Row -->
            <div class="stats-row" x-data="statsCounter()" x-init="init()">
              <div class="stat-item">
                <span class="stat-number">
                  <span x-ref="yearsEducation">0</span>+
                </span>
                <span class="stat-label">Years of Ayurvedic Education</span>
              </div>
              <div class="stat-divider" aria-hidden="true"></div>
              <div class="stat-item">
                <span class="stat-number">
                  <span x-ref="yearsPractice">0</span>+
                </span>
                <span class="stat-label">Years of Clinical Practice</span>
              </div>
            </div>

            <p class="founder-text">
              An Ayurvedic physician trained in India — the origin of this medical tradition — holding a Bachelor's, Master's, and PhD in Ayurveda. She completed over 11 years of formal Ayurvedic education and has since built more than 5 years of clinical practice.
            </p>
            <p class="founder-text">
              As founder of Ayurvedic Wellness House, she combines authentic Ayurvedic medicine with traditional Nusantara healing wisdom to build personalized wellness programs that restore balance across body, mind, and spirit. Her approach pairs evidence-based Ayurvedic principles with attentive, personalized care — driven by a goal of bringing authentic Ayurveda to Indonesia and beyond.
            </p>
            <a href="/contact" class="founder-cta">
              Book a consultation with Dr. Komang
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="5" y1="12" x2="19" y2="12"></line>
                <polyline points="12 5 19 12 12 19"></polyline>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </section>

    <SectionDivider />

    <!-- Team Section -->
    <section class="team section">
      <div class="container">
        <div class="team-inner">
          <h2 class="team-title">Our Team</h2>

          <div class="team-grid">
            <!-- Aji -->
            <ProfileCard
              name="Aji"
              role="Javanese Healer &amp; Reflexology Therapist"
              bio="A traditional healer and experienced reflexology therapist, born in Solo, rooted in Indonesian healing heritage. He follows the discipline of a traditional healing lineage — bringing focus, presence, and care to every session to restore balance, release tension, and support the body's natural healing process."
              image=""
              variant="small"
            />

            <!-- Trained Ayurvedic Therapist -->
            <ProfileCard
              name="Therapist"
              role="Trained Ayurvedic Therapist"
              bio="Trained directly by Dr. Komang Sudarmi, founder of Ayurvedic Wellness House. Each therapist upholds the standards of authentic Ayurvedic practice and personalized care that define our approach."
              image=""
              variant="small"
            />
          </div>
        </div>
      </div>
    </section>

  </main>

  <!-- Stats Counter Alpine Component -->
  <script>
    function statsCounter() {
      return {
        init() {
          const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
          const el = this.$el;

          const animate = () => {
            this.countUp(this.$refs.yearsEducation, 11);
            this.countUp(this.$refs.yearsPractice, 5);
          };

          if (prefersReducedMotion) {
            // Just set final values without animation
            this.$refs.yearsEducation.textContent = '11';
            this.$refs.yearsPractice.textContent = '5';
          } else {
            // Use IntersectionObserver to trigger when visible
            const observer = new IntersectionObserver((entries) => {
              entries.forEach(entry => {
                if (entry.isIntersecting) {
                  animate();
                  observer.unobserve(el);
                }
              });
            }, { threshold: 0.3 });
            observer.observe(this.$el);
          }
        },
        countUp(el, target) {
          const duration = 1500;
          const start = performance.now();
          const animate = (now) => {
            const elapsed = now - start;
            const progress = Math.min(elapsed / duration, 1);
            const eased = 1 - Math.pow(1 - progress, 3); // ease-out cubic
            el.textContent = Math.round(eased * target);
            if (progress < 1) requestAnimationFrame(animate);
          };
          requestAnimationFrame(animate);
        }
      };
    }
    window.statsCounter = statsCounter;
  </script>

  <Footer />
  <FloatingWhatsApp />
</BaseLayout>

<style>
  /* Page Header */
  .page-header {
    background-color: var(--color-cream-base);
    padding-top: clamp(6rem, 12vw, 10rem);
    padding-bottom: clamp(3rem, 6vw, 6rem);
    text-align: center;
  }

  .page-eyebrow {
    font-family: 'Karla', sans-serif;
    font-size: 0.8125rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-gold);
    margin-bottom: 1rem;
  }

  .page-title {
    font-family: 'Fraunces', Georgia, serif;
    font-size: clamp(2rem, 1.25rem + 3vw, 3.5rem);
    font-weight: 400;
    color: var(--color-olive);
    max-width: 24ch;
    margin: 0 auto;
    line-height: 1.15;
  }

  /* Founder Section */
  .founder-inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: start;
  }

  @media (min-width: 1024px) {
    .founder-inner {
      grid-template-columns: 5fr 7fr;
      gap: 5rem;
      align-items: center;
    }
  }

  .founder-portrait__image .img-placeholder {
    aspect-ratio: 4 / 5;
  }

  .founder-name {
    font-family: 'Fraunces', Georgia, serif;
    font-size: clamp(1.5rem, 1rem + 2vw, 2rem);
    font-weight: 500;
    color: var(--color-olive);
    margin-bottom: 0.5rem;
  }

  .founder-role {
    font-family: 'Karla', sans-serif;
    font-size: 0.8125rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-gold);
    margin-bottom: 1.5rem;
  }

  .founder-divider {
    width: 3rem;
    height: 1px;
    background-color: var(--color-gold);
    margin-bottom: 1.5rem;
  }

  /* Stats Row */
  .stats-row {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin-bottom: 1.5rem;
    padding: 1rem 0;
    border-top: 1px solid var(--color-cream-deep);
    border-bottom: 1px solid var(--color-cream-deep);
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .stat-number {
    font-family: 'Fraunces', Georgia, serif;
    font-size: clamp(1.5rem, 1rem + 2vw, 2rem);
    font-weight: 500;
    color: var(--color-olive);
    line-height: 1;
  }

  .stat-label {
    font-family: 'Karla', sans-serif;
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-sage);
  }

  .stat-divider {
    width: 1px;
    height: 2.5rem;
    background-color: var(--color-gold);
    opacity: 0.4;
    flex-shrink: 0;
  }

  .founder-text {
    font-size: clamp(1rem, 0.9375rem + 0.25vw, 1.0625rem);
    color: var(--color-olive);
    opacity: 0.85;
    line-height: 1.75;
    margin-bottom: 1rem;
  }

  .founder-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: 'Karla', sans-serif;
    font-size: 0.875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-sage);
    margin-top: 1rem;
    transition: color 0.2s ease;
  }

  .founder-cta:hover {
    color: var(--color-olive);
  }

  .founder-cta svg {
    width: 1rem;
    height: 1rem;
    transition: transform 0.2s ease;
  }

  .founder-cta:hover svg {
    transform: translateX(4px);
  }

  /* Team Section */
  .team-inner {
    max-width: 56rem;
    margin: 0 auto;
  }

  .team-title {
    font-family: 'Fraunces', Georgia, serif;
    font-size: clamp(1.5rem, 1rem + 2vw, 2rem);
    font-weight: 400;
    color: var(--color-olive);
    text-align: center;
    margin-bottom: 3rem;
  }

  .team-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  @media (min-width: 768px) {
    .team-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
