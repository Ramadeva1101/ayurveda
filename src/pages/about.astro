---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import FloatingWhatsApp from '../components/FloatingWhatsApp.astro';
import SectionDivider from '../components/SectionDivider.astro';
// Using plain <img> tags with .src for Cloudflare Pages compatibility
import drKomangImg from '../assets/images/dr-komang-portrait.webp';
import ajiImg from '../assets/images/aji-portrait.webp';
import therapistImg from '../assets/images/therapist-portrait.webp';
---

<BaseLayout
  title="About Us"
  description="Meet Dr. Komang Sudarmi, Ayurvedic Physician and Founder of Ayurvedic Wellness House, and our team of trained therapists."
>
  <Navbar />

  <main id="main-content">

    <!-- Page Header -->
    <section class="page-header section">
      <div class="container">
        <p class="page-eyebrow">About Us</p>
        <h1 class="page-title">The People &amp; Philosophy<br/>Behind Our Healing</h1>
        <p class="page-subtitle">Rooted in ancient wisdom, guided by compassionate care.</p>
      </div>
    </section>

    <!-- Our Uniqueness Section -->
    <section class="uniqueness section">
      <div class="container">
        <p class="section-eyebrow">Our Uniqueness</p>
        <h2 class="uniqueness__title">Where Two Ancient Healing Traditions Meet</h2>
        <p class="uniqueness__lead">
          At Ayurvedic Wellness House, we bring together the timeless wisdom of Classical Ayurveda and the rich heritage of Nusantara Traditional Healing to create a personalized wellness experience unlike any other.
        </p>

        <div class="uniqueness-grid">

          <!-- Ayurveda -->
          <div class="uniqueness-card">
            <div class="uniqueness-card__icon">
              <!-- Leaf/herb icon — represents Ayurveda (Science of Life, herbal medicine) -->
              <svg viewBox="0 0 24 24" fill="none" stroke="#B8935A" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10z"></path>
                <path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"></path>
              </svg>
            </div>
            <h3 class="uniqueness-card__title">What is Ayurveda?</h3>
            <div class="uniqueness-card__divider"></div>
            <p class="uniqueness-card__text">
              Ayurveda, meaning <em>"The Science of Life,"</em> is a traditional medical system from India with over 5,000 years of history. It focuses on restoring balance through personalized consultation, herbal medicine, therapeutic treatments, nutrition, and healthy lifestyle practices.
            </p>
            <p class="uniqueness-card__text">
              Rather than treating symptoms alone, Ayurveda aims to support the body's natural ability to heal and maintain long-term well-being.
            </p>
          </div>

          <!-- Nusantara -->
          <div class="uniqueness-card">
            <div class="uniqueness-card__icon">
              <!-- Waves/archipelago icon — represents Nusantara (Indonesian island heritage) -->
              <svg viewBox="0 0 24 24" fill="none" stroke="#B8935A" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M2 6c.6.5 1.2 1 2.5 1C7 7 7 5 9.5 5c2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"></path>
                <path d="M2 12c.6.5 1.2 1 2.5 1C7 13 7 11 9.5 11c2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"></path>
                <path d="M2 18c.6.5 1.2 1 2.5 1C7 19 7 17 9.5 17c2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"></path>
              </svg>
            </div>
            <h3 class="uniqueness-card__title">What is Nusantara Traditional Healing?</h3>
            <div class="uniqueness-card__divider"></div>
            <p class="uniqueness-card__text">
              Nusantara Traditional Healing is Indonesia's traditional healing heritage, developed over generations using local herbs, therapeutic bodywork, and natural healing practices.
            </p>
            <p class="uniqueness-card__text">
              It emphasizes harmony between the body, mind, nature, and spirit — reflecting the diverse wisdom found throughout the Indonesian archipelago.
            </p>
          </div>

          <!-- Why Combine -->
          <div class="uniqueness-card uniqueness-card--highlight">
            <div class="uniqueness-card__icon">
              <!-- Merge/infinity icon — represents combining two traditions into one holistic path -->
              <svg viewBox="0 0 24 24" fill="none" stroke="#B8935A" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M18.178 8c5.096 0 5.096 8 0 8-5.095 0-7.133-8-12.739-8-4.585 0-4.585 8 0 8 5.606 0 7.644-8 12.74-8z"></path>
              </svg>
            </div>
            <h3 class="uniqueness-card__title">Why Combine Both?</h3>
            <div class="uniqueness-card__divider"></div>
            <p class="uniqueness-card__text">
              Although they come from different cultures, both traditions share the same philosophy. By combining them, we create a unique healing experience that is both authentic and deeply personalized — honoring the body, mind, nature, and spirit as one.
            </p>
            <ul class="uniqueness-list">
              <li>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
                Treat the whole person, not just the symptoms
              </li>
              <li>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
                Restore balance naturally
              </li>
              <li>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
                Use herbs and therapeutic touch
              </li>
              <li>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
                Support the body's own healing process
              </li>
              <li>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
                Encourage a healthy lifestyle for lasting wellness
              </li>
            </ul>
          </div>

        </div>
      </div>
    </section>

    <SectionDivider />

    <!-- Meet Our People Section -->
    <section class="meet-people section">
      <div class="container">
        <h2 class="meet-people__title">Meet Our People</h2>
      </div>
    </section>

    <SectionDivider variant="simple" />

    <!-- Dr. Komang — Large, Prominent Founder Profile -->
    <section class="founder section section--alt">
      <div class="container">
        <div class="founder-inner">
          <div class="founder-portrait">
            <div class="founder-portrait__image">
              <img
                src={drKomangImg.src}
                alt="Dr. Komang Sudarmi, Founder & Chief Ayurvedic Physician"
                class="founder-portrait__img"
                width={600}
                height={drKomangImg.height}
                loading="lazy"
                decoding="async"
              />
            </div>
          </div>

          <div class="founder-bio">
            <p class="founder-title">Dr. Komang Sudarmi, BAMS., MS., PhD (Ayurveda)</p>
            <p class="founder-role">Founder &amp; Chief Ayurvedic Physician</p>
            <div class="founder-divider" aria-hidden="true"></div>

            <p class="founder-text">
              Dr. Komang Sudarmi is an internationally trained Ayurvedic physician with over 11 years of formal education in Ayurveda and more than five years of clinical experience. She earned her Bachelor's, Master's, and PhD in Ayurveda in India — the birthplace of this ancient healing science.
            </p>
            <p class="founder-text">
              As the founder of Ayurvedic Wellness House, Dr. Komang integrates authentic Ayurvedic medicine with the traditional healing wisdom of Nusantara to provide personalized wellness programs that restore balance to the body, mind, and spirit. Her approach combines evidence-based Ayurvedic principles with compassionate, individualized care, creating transformative healing experiences for every guest.
            </p>
            <p class="founder-text">
              Driven by a vision to introduce authentic Ayurveda to Indonesia and the world, Dr. Komang is dedicated to helping people achieve lasting health through natural, holistic healing.
            </p>
            <a href="/contact" class="founder-cta">
              Book a consultation with Dr. Komang
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="5" y1="12" x2="19" y2="12"></line>
                <polyline points="12 5 19 12 12 19"></polyline>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </section>

    <SectionDivider variant="simple" />

    <!-- Team Section -->
    <section class="team section">
      <div class="container">
        <div class="team-grid">

          <!-- Aji — Javanese Healer -->
          <div class="team-member">
            <div class="member-portrait">
              <img
                src={ajiImg.src}
                alt="Aji, Javanese Healer"
                class="member-portrait__img"
                width={400}
                height={ajiImg.height}
                loading="lazy"
                decoding="async"
              />
            </div>
            <div class="member-info">
              <p class="member-label">JAVANESE HEALER</p>
              <p class="member-name">Aji</p>
              <div class="member-divider" aria-hidden="true"></div>
              <p class="member-text">
                Aji is a devoted traditional healer and experienced reflexology therapist, born in Solo and deeply rooted in Indonesia's healing heritage. Guided by the sacred discipline of traditional healer lineage, Aji embodies self-discipline, presence, and compassion in every treatment. His approach is designed to restore harmony, release tension, and support the body's natural healing process — offering guests a deeply grounding and rejuvenating wellness experience.
              </p>
            </div>
          </div>

          <!-- Trained Ayurvedic Therapist -->
          <div class="team-member">
            <div class="member-portrait">
              <img
                src={therapistImg.src}
                alt="Our Trained Ayurvedic Therapist"
                class="member-portrait__img"
                width={400}
                height={therapistImg.height}
                loading="lazy"
                decoding="async"
              />
            </div>
            <div class="member-info">
              <p class="member-label">TRAINED AYURVEDIC THERAPIST</p>
              <p class="member-name">Our Therapist</p>
              <div class="member-divider" aria-hidden="true"></div>
              <p class="member-text">
                Trained by Doc K, our Ayurvedic therapists bring dedication, skill, and warmth to every session. Each therapist has completed rigorous training under Dr. Komang Sudarmi's guidance, ensuring every treatment meets the highest standards of authentic Ayurvedic practice. They work alongside Dr. Komang to deliver personalized healing experiences rooted in classical Ayurvedic principles and the healing wisdom of Nusantara.
              </p>
            </div>
          </div>

        </div>
      </div>
    </section>

  </main>

  <Footer />
  <FloatingWhatsApp />
</BaseLayout>

<style>
  .page-header {
    background-color: var(--color-cream-base);
    padding-top: clamp(6rem, 12vw, 10rem);
    padding-bottom: clamp(2rem, 4vw, 3.5rem);
    text-align: center;
  }

  .page-eyebrow {
    font-family: 'Karla', sans-serif;
    font-size: 0.8125rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-gold);
    margin-bottom: 1rem;
  }

  .page-title {
    font-family: 'Fraunces', Georgia, serif;
    font-size: clamp(2.25rem, 1.5rem + 3.5vw, 4rem);
    font-weight: 400;
    color: var(--color-olive);
    max-width: 22ch;
    margin: 0 auto 1.25rem;
    line-height: 1.15;
  }

  .page-subtitle {
    font-family: 'Karla', sans-serif;
    font-size: clamp(1rem, 0.9rem + 0.5vw, 1.125rem);
    color: var(--color-olive);
    opacity: 0.65;
    max-width: 36ch;
    margin: 0 auto;
    line-height: 1.6;
  }

  /* Founder Section */
  .founder-inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: start;
  }

  @media (min-width: 1024px) {
    .founder-inner {
      grid-template-columns: 5fr 7fr;
      gap: 5rem;
      align-items: center;
    }
  }

  .founder-portrait__image .img-placeholder,
  .founder-portrait__img {
    aspect-ratio: 4 / 5;
    width: 100%;
    display: block;
    object-fit: cover;
    object-position: center top;
  }

  .founder-bio {
    order: -1;
  }

  @media (min-width: 1024px) {
    .founder-bio {
      order: 0;
    }
  }

  .founder-title {
    font-family: 'Fraunces', Georgia, serif;
    font-size: clamp(1.25rem, 1rem + 1.5vw, 1.75rem);
    font-weight: 500;
    color: var(--color-olive);
    margin-bottom: 0.25rem;
    line-height: 1.3;
  }

  .founder-role {
    font-family: 'Karla', sans-serif;
    font-size: 0.8125rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-gold);
    margin-bottom: 1.5rem;
  }

  .founder-divider {
    width: 3rem;
    height: 1px;
    background-color: var(--color-gold);
    margin-bottom: 1.5rem;
  }

  .founder-text {
    font-size: clamp(1rem, 0.9375rem + 0.25vw, 1.0625rem);
    color: var(--color-olive);
    opacity: 0.85;
    line-height: 1.75;
    margin-bottom: 1rem;
  }

  .founder-text:last-of-type {
    margin-bottom: 0;
  }

  .founder-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: 'Karla', sans-serif;
    font-size: 0.875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-sage);
    margin-top: 1.5rem;
    transition: color 0.2s ease;
    text-decoration: none;
  }

  .founder-cta:hover {
    color: var(--color-olive);
  }

  .founder-cta svg {
    width: 1rem;
    height: 1rem;
    transition: transform 0.2s ease;
  }

  .founder-cta:hover svg {
    transform: translateX(4px);
  }

  /* Meet Our People heading */
  .meet-people__title {
    font-family: 'Fraunces', Georgia, serif;
    font-size: clamp(1.75rem, 1.25rem + 2vw, 2.75rem);
    font-weight: 400;
    color: var(--color-olive);
    text-align: center;
    margin: 0;
  }

  .team-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 4rem;
  }

  @media (min-width: 768px) {
    .team-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 3rem;
    }
  }

  .team-member {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    align-items: start;
  }

  @media (min-width: 640px) {
    .team-member {
      grid-template-columns: 5fr 7fr;
      gap: 2rem;
    }
  }

  .member-portrait .img-placeholder,
  .member-portrait__img {
    aspect-ratio: 4 / 5;
    width: 100%;
    display: block;
    object-fit: cover;
    object-position: center top;
  }

  .member-info {
    order: -1;
  }

  @media (min-width: 640px) {
    .member-info {
      order: 0;
    }
  }

  .member-label {
    font-family: 'Karla', sans-serif;
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-sage);
    margin-bottom: 0.5rem;
  }

  .member-name {
    font-family: 'Fraunces', Georgia, serif;
    font-size: clamp(1.25rem, 1rem + 1.5vw, 1.5rem);
    font-weight: 500;
    color: var(--color-olive);
    margin-bottom: 0.25rem;
  }

  .member-divider {
    width: 3rem;
    height: 1px;
    background-color: var(--color-gold);
    margin-bottom: 1.25rem;
  }

  .member-text {
    font-size: clamp(0.9375rem, 0.875rem + 0.25vw, 1rem);
    color: var(--color-olive);
    opacity: 0.85;
    line-height: 1.75;
    margin: 0;
  }

  /* Section eyebrow shared style */
  .section-eyebrow {
    font-family: 'Karla', sans-serif;
    font-size: 0.8125rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-gold);
    text-align: center;
    margin-bottom: 0.75rem;
  }

  /* Our Uniqueness Section */
  .uniqueness {
    background-color: var(--color-cream-base);
    padding-top: clamp(2rem, 4vw, 3.5rem);
  }

  .uniqueness__title {
    font-family: 'Fraunces', Georgia, serif;
    font-size: clamp(1.75rem, 1.25rem + 2vw, 2.5rem);
    font-weight: 400;
    color: var(--color-olive);
    text-align: center;
    margin-bottom: 1.5rem;
    line-height: 1.2;
  }

  .uniqueness__lead {
    font-size: clamp(1rem, 0.9375rem + 0.25vw, 1.0625rem);
    color: var(--color-olive);
    opacity: 0.8;
    text-align: center;
    max-width: 48rem;
    margin: 0 auto 3rem;
    line-height: 1.7;
  }

  .uniqueness-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  @media (min-width: 768px) {
    .uniqueness-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .uniqueness-card {
    background-color: var(--color-cream-deep);
    padding: 2rem;
    display: flex;
    flex-direction: column;
  }

  .uniqueness-card--highlight {
    background-color: var(--color-olive);
  }

  .uniqueness-card__icon {
    width: 3rem;
    height: 3rem;
    margin-bottom: 1.25rem;
  }

  .uniqueness-card__icon svg {
    width: 100%;
    height: 100%;
  }

  .uniqueness-card__title {
    font-family: 'Fraunces', Georgia, serif;
    font-size: clamp(1.0625rem, 1rem + 0.5vw, 1.25rem);
    font-weight: 500;
    color: var(--color-olive);
    margin-bottom: 0.75rem;
    line-height: 1.3;
  }

  .uniqueness-card--highlight .uniqueness-card__title {
    color: var(--color-cream-base);
  }

  .uniqueness-card__divider {
    width: 2.5rem;
    height: 1px;
    background-color: var(--color-gold);
    margin-bottom: 1.25rem;
  }

  .uniqueness-card__text {
    font-size: clamp(0.9375rem, 0.875rem + 0.25vw, 1rem);
    color: var(--color-olive);
    opacity: 0.85;
    line-height: 1.75;
    margin-bottom: 0.75rem;
  }

  .uniqueness-card--highlight .uniqueness-card__text {
    color: var(--color-cream-base);
    opacity: 0.9;
  }

  .uniqueness-card__text:last-of-type {
    margin-bottom: 0;
  }

  .uniqueness-list {
    list-style: none;
    padding: 0;
    margin: 1rem 0 0;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .uniqueness-list li {
    display: flex;
    align-items: flex-start;
    gap: 0.625rem;
    font-size: clamp(0.875rem, 0.8125rem + 0.25vw, 0.9375rem);
    color: var(--color-cream-base);
    opacity: 0.9;
    line-height: 1.5;
  }

  .uniqueness-list li svg {
    width: 1rem;
    height: 1rem;
    flex-shrink: 0;
    color: var(--color-gold);
    margin-top: 0.2rem;
  }
</style>
