---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import FloatingWhatsApp from '../components/FloatingWhatsApp.astro';
import SectionDivider from '../components/SectionDivider.astro';
import { Image } from 'astro:assets';

// BSR Gallery images — imported via Astro asset system for full optimisation
import bsrMountainsImg from '../assets/images/bsr-mountains.webp';
import bsrDroneImg from '../assets/images/bsr-drone-landscape.jpg';
import bsrJunglePathImg from '../assets/images/bsr-jungle-heart-path.jpg';
import bsrMeditationOctagonImg from '../assets/images/bsr-meditation-octagon.jpg';
import bsrMeditationStepsImg from '../assets/images/bsr-meditation-steps.jpg';
import bsrLodgeLibraryImg from '../assets/images/bsr-lodge-library.jpg';
import bsrCryingBenchImg from '../assets/images/bsr-crying-bench.jpg';
import bsrLabyrinthImg from '../assets/images/bsr-labyrinth.jpg';
import bsrDucksImg from '../assets/images/bsr-ducks-harvest.jpg';
import bsrStarGazingImg from '../assets/images/bsr-star-gazing.jpg';
import bsrSilentLibraryImg from '../assets/images/bsr-silent-library.jpg';
import bsrGoodMorningImg from '../assets/images/bsr-good-morning.jpg';
import bsrFreshFoodImg from '../assets/images/bsr-fresh-food.jpg';
import bsrVerandaImg from '../assets/images/bsr-veranda.webp';
import bsrTreatmentRoomImg from '../assets/images/bsr-treatment-room.webp';
import bsrRoomsImg from '../assets/images/bsr-rooms.webp';
import bsrRiceFieldsImg from '../assets/images/bsr-rice-fields.webp';
---

<BaseLayout
  title="Our Healing Sanctuary"
  description="Ayurvedic Wellness House is hosted at Bali Silent Retreat — a peaceful wellness destination surrounded by rice fields, tropical forests, and Mount Batukaru."
>
  <Navbar />

  <main id="main-content">

    <!-- Page Header -->
    <section class="page-header section">
      <div class="container">
        <p class="page-eyebrow">Our Location</p>
        <h1 class="page-title">Our Healing Sanctuary</h1>
        <p class="page-subtitle">Hosted at Bali Silent Retreat</p>
      </div>
    </section>

    <!-- Main Content -->
    <section class="sanctuary-intro section">
      <div class="container">
        <div class="sanctuary-intro__inner">
          <h2 class="sanctuary-intro__lead">
            Healing is not only about the treatments you receive — it is also about the environment that surrounds you.
          </h2>
          <div class="sanctuary-intro__text">
            <p>
              Ayurvedic Wellness House is proudly hosted near by <strong>Bali Silent Retreat</strong>, a peaceful wellness destination in the heart of Bali. Surrounded by rice fields, tropical forests, and the breathtaking views of Mount Batukaru, our location offers the ideal setting to rest, reconnect, and restore your well-being.
            </p>
            <p>
              Whether you are visiting for a consultation, a daily wellness experience, or a multi-day program, the calm atmosphere of Bali Silent Retreat becomes an important part of your healing journey.
            </p>
          </div>
        </div>
      </div>
    </section>

    <SectionDivider />

    <!-- A Place Designed for Healing -->
    <section class="highlights section section--alt">
      <div class="container">
        <h2 class="highlights__title">A Place Designed for Healing</h2>
        <p class="highlights__subtitle">Our guests enjoy a tranquil environment where nature encourages deep relaxation and reflection.</p>
        <div class="highlights__grid">
          <div class="highlight-item">
            <div class="highlight-icon">
              <!-- Mountain icon — Spectacular Views of Mount Batukaru -->
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M8 3l4 8 5-5 5 15H2L8 3z"></path>
              </svg>
            </div>
            <h3>Spectacular Views of Mount Batukaru</h3>
          </div>
          <div class="highlight-item">
            <div class="highlight-icon">
              <!-- Sprout/plant icon — Peaceful Rice Field Surroundings -->
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M7 20h10"></path>
                <path d="M10 20c5.5-2.5.8-6.4 3-10"></path>
                <path d="M9.5 9.4c1.1.8 1.8 2.2 2.3 3.7-2 .4-3.5.4-4.8-.3-1.2-.6-2.3-1.9-3-4.2 2.8-.5 4.4 0 5.5.8z"></path>
                <path d="M14.1 6a7 7 0 0 0-1.1 4c1.9-.1 3.3-.6 4.3-1.4 1-1 1.6-2.3 1.7-4.6-2.7.1-4 1-4.9 2z"></path>
              </svg>
            </div>
            <h3>Peaceful Rice Field Surroundings</h3>
          </div>
          <div class="highlight-item">
            <div class="highlight-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M17.5 19H9a7 7 0 1 1 6.71-9h1.79a4.5 4.5 0 1 1 0 9Z"></path>
              </svg>
            </div>
            <h3>Fresh Mountain Air</h3>
          </div>
          <div class="highlight-item">
            <div class="highlight-icon">
              <!-- Lotus/meditation icon — Quiet Spaces for Meditation and Relaxation -->
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 22c0 0-8-5.4-8-11.8C4 6.3 7.6 3 12 3s8 3.3 8 7.2C20 16.6 12 22 12 22z"></path>
                <path d="M12 22c0 0-4-4.2-4-8.2 0-2.5 1.8-4.5 4-4.5s4 2 4 4.5c0 4-4 8.2-4 8.2z"></path>
              </svg>
            </div>
            <h3>Quiet Spaces for Meditation and Relaxation</h3>
          </div>
          <div class="highlight-item">
            <div class="highlight-icon">
              <!-- Palm/tropical icon — Beautiful Tropical Gardens -->
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M13 8c0-2.76-2.46-5-5.5-5S2 5.24 2 8h2l1-1 1 1h4"></path>
                <path d="M13 7.14A5.82 5.82 0 0 1 16.5 6c3.04 0 5.5 2.24 5.5 5h-3l-1-1-1 1h-3"></path>
                <path d="M5.89 9.71c-2.15 2.15-2.3 5.47-.35 7.43l4.24-4.25.7-.7.71-.71 2.12-2.12c-1.95-1.96-5.27-1.8-7.42.35z"></path>
                <path d="M11 15.5c.5 2.5-.17 4.5-1 6.5h4c2-5.5-.5-10-2-10z"></path>
              </svg>
            </div>
            <h3>Beautiful Tropical Gardens</h3>
          </div>
          <div class="highlight-item">
            <div class="highlight-icon">
              <!-- Leaf/renewal icon — A Natural Environment That Supports Rest and Renewal -->
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10z"></path>
                <path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"></path>
              </svg>
            </div>
            <h3>A Natural Environment That Supports Rest and Renewal</h3>
          </div>
        </div>
      </div>
    </section>

    <SectionDivider variant="simple" />

    <!-- Why This Location -->
    <section class="why-location section">
      <div class="container">
        <div class="why-location__inner">
          <h2 class="why-location__title">Why This Location?</h2>
          <p class="why-location__text">
            We believe that true healing happens when professional care is combined with a peaceful environment.
          </p>
          <p class="why-location__text">
            The combination of authentic Ayurveda, the healing traditions of Nusantara, and the serene surroundings of Bali Silent Retreat — known as a hidden gem: an eco-sustainable nature sanctuary, with a 6 hectares of nature, surrounded by UNESCO-Jatiluwih rice fields, jungle, and mountains — creates a unique opportunity to step away from daily life, reconnect with yourself, and embrace a healthier way of living.
          </p>
        </div>
      </div>
    </section>

    <SectionDivider />

    <!-- BSR Photo Gallery -->
    <section class="bsr-gallery section">
      <div class="container">
        <div class="gallery-header">
          <p class="gallery-eyebrow">Bali Silent Retreat</p>
          <h2 class="gallery-title">A Sanctuary Beyond Words</h2>
          <p class="gallery-subtitle">Immerse yourself in 6 hectares of nature — where rice fields, jungle, and mountain air create the perfect backdrop for healing.</p>
        </div>

        <!-- Mountains panorama — standalone cinematic banner -->
        <div class="gallery-panorama">
          <Image
            src={bsrMountainsImg}
            alt="Three sisters mountains viewed from Jatiluwih rice fields at Bali Silent Retreat"
            width={1440}
            height={540}
            format="webp"
            quality={85}
            loading="lazy"
          />
          <div class="gallery-overlay">
            <span>Jatiluwih Rice Fields &amp; Three Sisters Mountains</span>
          </div>
        </div>

        <div class="gallery-grid">

          <!-- ROW 1: Drone(2×2) + Jungle path(1×2) + Meditation octagon + Meditation steps -->
          <div class="gallery-item gallery-item--large">
            <Image
              src={bsrDroneImg}
              alt="Aerial view of Bali Silent Retreat surrounded by rice fields and jungle"
              width={800}
              height={600}
              format="webp"
              quality={85}
              loading="lazy"
            />
            <div class="gallery-overlay">
              <span>Aerial View — 6 Hectares of Nature</span>
            </div>
          </div>

          <div class="gallery-item gallery-item--tall">
            <Image
              src={bsrJunglePathImg}
              alt="Heart-shaped jungle path at Bali Silent Retreat"
              width={800}
              height={600}
              format="webp"
              quality={85}
              loading="lazy"
            />
            <div class="gallery-overlay">
              <span>Heart-Shaped Jungle Path</span>
            </div>
          </div>

          <div class="gallery-item">
            <Image
              src={bsrMeditationOctagonImg}
              alt="Meditation octagon bale pavilion"
              width={800}
              height={600}
              format="webp"
              quality={85}
              loading="lazy"
            />
            <div class="gallery-overlay">
              <span>Meditation Octagon Bale</span>
            </div>
          </div>

          <div class="gallery-item">
            <Image
              src={bsrMeditationStepsImg}
              alt="Meditation steps surrounded by nature"
              width={800}
              height={600}
              format="webp"
              quality={85}
              loading="lazy"
            />
            <div class="gallery-overlay">
              <span>Meditation Steps</span>
            </div>
          </div>

          <!-- ROW 3: Lodge(wide) + Crying bench + Labyrinth -->
          <div class="gallery-item gallery-item--wide">
            <Image
              src={bsrLodgeLibraryImg}
              alt="Lodge library relaxation area"
              width={800}
              height={600}
              format="webp"
              quality={85}
              loading="lazy"
            />
            <div class="gallery-overlay">
              <span>Library &amp; Relaxation Lodge</span>
            </div>
          </div>

          <div class="gallery-item">
            <Image
              src={bsrCryingBenchImg}
              alt="Guest sitting on crying bench in nature"
              width={800}
              height={600}
              format="webp"
              quality={85}
              loading="lazy"
            />
            <div class="gallery-overlay">
              <span>The Crying Bench</span>
            </div>
          </div>

          <div class="gallery-item">
            <Image
              src={bsrLabyrinthImg}
              alt="Labyrinth walking meditation program"
              width={800}
              height={600}
              format="webp"
              quality={85}
              loading="lazy"
            />
            <div class="gallery-overlay">
              <span>Labyrinth Walking Meditation</span>
            </div>
          </div>

          <!-- ROW 4: Ducks(wide) + Star gazing + Silent library -->
          <div class="gallery-item gallery-item--wide">
            <Image
              src={bsrDucksImg}
              alt="Eco-friendly ducks after rice harvest at Bali Silent Retreat"
              width={800}
              height={600}
              format="webp"
              quality={85}
              loading="lazy"
            />
            <div class="gallery-overlay">
              <span>Eco-Friendly Life — Ducks After Rice Harvest</span>
            </div>
          </div>

          <div class="gallery-item">
            <Image
              src={bsrStarGazingImg}
              alt="Star gazing on star bed at dusk"
              width={800}
              height={600}
              format="webp"
              quality={85}
              loading="lazy"
            />
            <div class="gallery-overlay">
              <span>Star Gazing at Dusk</span>
            </div>
          </div>

          <div class="gallery-item">
            <Image
              src={bsrSilentLibraryImg}
              alt="Guest reading in the library"
              width={800}
              height={600}
              format="webp"
              quality={85}
              loading="lazy"
            />
            <div class="gallery-overlay">
              <span>The Silent Library</span>
            </div>
          </div>

          <!-- ROW 5: Rice fields + Morning + Traditional veranda(wide) -->
          <div class="gallery-item">
            <Image
              src={bsrRiceFieldsImg}
              alt="Jatiluwih rice fields with mountain backdrop"
              width={800}
              height={600}
              format="webp"
              quality={85}
              loading="lazy"
            />
            <div class="gallery-overlay">
              <span>Jatiluwih UNESCO Rice Fields</span>
            </div>
          </div>

          <div class="gallery-item">
            <Image
              src={bsrGoodMorningImg}
              alt="Morning view from guest perspective at Bali Silent Retreat"
              width={800}
              height={600}
              format="webp"
              quality={85}
              loading="lazy"
            />
            <div class="gallery-overlay">
              <span>Good Morning from the Retreat</span>
            </div>
          </div>

          <div class="gallery-item gallery-item--wide">
            <Image
              src={bsrVerandaImg}
              alt="Traditional Javanese veranda with tropical garden"
              width={800}
              height={600}
              format="webp"
              quality={85}
              loading="lazy"
            />
            <div class="gallery-overlay">
              <span>Traditional Javanese Veranda</span>
            </div>
          </div>

          <!-- ROW 6: Accommodation rooms(wide) + Treatment room + Fresh food -->
          <div class="gallery-item gallery-item--wide">
            <Image
              src={bsrRoomsImg}
              alt="Accommodation rooms with colorful Javanese doors"
              width={800}
              height={600}
              format="webp"
              quality={85}
              loading="lazy"
            />
            <div class="gallery-overlay">
              <span>Accommodation Rooms</span>
            </div>
          </div>

          <div class="gallery-item">
            <Image
              src={bsrTreatmentRoomImg}
              alt="Authentic treatment room with wooden bed"
              width={800}
              height={600}
              format="webp"
              quality={85}
              loading="lazy"
            />
            <div class="gallery-overlay">
              <span>Treatment Room</span>
            </div>
          </div>

          <div class="gallery-item">
            <Image
              src={bsrFreshFoodImg}
              alt="Fresh wholesome food at the retreat"
              width={800}
              height={600}
              format="webp"
              quality={85}
              loading="lazy"
            />
            <div class="gallery-overlay">
              <span>Fresh Wholesome Food</span>
            </div>
          </div>

        </div>
      </div>
    </section>

    <SectionDivider />

    <!-- Accommodation Note -->
    <section class="accommodation-note section section--dark">
      <div class="container">
        <div class="note-inner">
          <p class="note-text">
            <strong>Note:</strong> For accommodation and meal bookings, please visit
          </p>
          <a href="https://www.balisilentretreat.com" target="_blank" rel="noopener noreferrer" class="note-link btn btn-secondary">
            Bali Silent Retreat
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="7" y1="17" x2="17" y2="7"></line>
              <polyline points="7 7 17 7 17 17"></polyline>
            </svg>
          </a>
        </div>
      </div>
    </section>

  </main>

  <Footer />
  <FloatingWhatsApp />
</BaseLayout>

<style>
  .page-header {
    background-color: var(--color-cream-base);
    padding-top: clamp(6rem, 12vw, 10rem);
    padding-bottom: clamp(1rem, 2vw, 2.5rem);
    text-align: center;
  }

  .sanctuary-intro.section {
    padding-top: clamp(1.5rem, 3vw, 3rem);
  }

  /* ====================================
     BSR PHOTO GALLERY
  ==================================== */
  .bsr-gallery {
    background-color: var(--color-cream-deep);
    padding-top: clamp(3rem, 6vw, 6rem);
    padding-bottom: clamp(3rem, 6vw, 6rem);
  }

  .gallery-header {
    text-align: center;
    margin-bottom: clamp(2rem, 4vw, 3.5rem);
  }

  .gallery-eyebrow {
    font-family: 'Karla', sans-serif;
    font-size: 0.8125rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--color-gold);
    margin-bottom: 0.75rem;
  }

  .gallery-title {
    font-family: 'Fraunces', Georgia, serif;
    font-size: clamp(1.75rem, 1.25rem + 2.5vw, 3rem);
    font-weight: 400;
    color: var(--color-olive);
    margin-bottom: 1rem;
  }

  .gallery-subtitle {
    font-size: clamp(1rem, 0.9375rem + 0.25vw, 1.0625rem);
    color: var(--color-sage);
    max-width: 42rem;
    margin: 0 auto;
    line-height: 1.7;
  }

  /* Masonry-style auto grid */
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    grid-auto-rows: 220px;
    grid-auto-flow: dense;
    gap: 0.75rem;
  }

  @media (min-width: 640px) {
    .gallery-grid {
      grid-template-columns: repeat(3, 1fr);
      grid-auto-rows: 240px;
    }
  }

  @media (min-width: 1024px) {
    .gallery-grid {
      grid-template-columns: repeat(4, 1fr);
      grid-auto-rows: 260px;
      gap: 1rem;
    }
  }

  /* Base gallery item */
  .gallery-item {
    position: relative;
    overflow: hidden;
    cursor: pointer;
    background-color: var(--color-cream-deep);
  }

  /* Standalone panorama banner (outside grid) */
  .gallery-panorama {
    position: relative;
    width: 100%;
    height: 320px;
    overflow: hidden;
    margin-bottom: 1rem;
    cursor: pointer;
  }

  @media (min-width: 1024px) {
    .gallery-panorama {
      height: 380px;
      margin-bottom: 1rem;
    }
  }

  .gallery-panorama img {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    filter: brightness(0.92) saturate(1.05);
    transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94), filter 0.6s ease;
  }

  .gallery-panorama:hover img {
    transform: translate(-50%, -50%) scale(1.04);
    filter: brightness(0.75) saturate(1.15);
  }

  .gallery-panorama .gallery-overlay {
    opacity: 0;
  }

  .gallery-panorama:hover .gallery-overlay {
    opacity: 1;
  }

  .gallery-panorama::after {
    content: '';
    position: absolute;
    inset: 0;
    border: 0px solid var(--color-gold);
    transition: border-width 0.35s ease;
    pointer-events: none;
    z-index: 2;
  }

  .gallery-panorama:hover::after {
    border-width: 3px;
  }

  /* Size variants */
  .gallery-item--large {
    grid-column: span 2;
    grid-row: span 2;
  }

  .gallery-item--tall {
    grid-row: span 2;
  }

  .gallery-item--wide {
    grid-column: span 2;
  }

  .gallery-item img {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94),
                filter 0.6s ease;
    filter: brightness(0.92) saturate(1.05);
  }

  .gallery-item:hover img {
    transform: translate(-50%, -50%) scale(1.06);
    filter: brightness(0.75) saturate(1.15);
  }

  /* Overlay caption */
  .gallery-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: flex-end;
    padding: 1.25rem 1rem;
    background: linear-gradient(
      to top,
      rgba(30, 40, 20, 0.72) 0%,
      rgba(30, 40, 20, 0) 50%
    );
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  .gallery-item:hover .gallery-overlay {
    opacity: 1;
  }

  .gallery-overlay span {
    font-family: 'Karla', sans-serif;
    font-size: 0.8125rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(255, 255, 255, 0.92);
    transform: translateY(6px);
    transition: transform 0.4s ease;
  }

  .gallery-item:hover .gallery-overlay span {
    transform: translateY(0);
  }

  /* Thin gold border on hover */
  .gallery-item::after {
    content: '';
    position: absolute;
    inset: 0;
    border: 0px solid var(--color-gold);
    transition: border-width 0.35s ease;
    pointer-events: none;
    z-index: 2;
  }

  .gallery-item:hover::after {
    border-width: 3px;
  }

  .page-eyebrow {
    font-family: 'Karla', sans-serif;
    font-size: 0.8125rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-gold);
    margin-bottom: 1rem;
  }

  .page-title {
    font-family: 'Fraunces', Georgia, serif;
    font-size: clamp(2rem, 1.25rem + 3vw, 3.5rem);
    font-weight: 400;
    color: var(--color-olive);
    margin-bottom: 0.5rem;
  }

  .page-subtitle {
    font-family: 'Karla', sans-serif;
    font-size: 1rem;
    color: var(--color-sage);
    font-weight: 500;
    letter-spacing: 0.05em;
  }

  /* Sanctuary Intro */
  .sanctuary-intro__inner {
    max-width: 52rem;
    margin: 0 auto;
    text-align: center;
  }

  .sanctuary-intro__lead {
    font-family: 'Fraunces', Georgia, serif;
    font-size: clamp(1.375rem, 1rem + 1.5vw, 1.875rem);
    font-weight: 400;
    font-style: italic;
    color: var(--color-olive);
    line-height: 1.4;
    margin-bottom: 2rem;
  }

  .sanctuary-intro__text p {
    font-size: clamp(1rem, 0.9375rem + 0.25vw, 1.0625rem);
    color: var(--color-olive);
    opacity: 0.85;
    line-height: 1.75;
    text-align: left;
  }

  /* Highlights */
  .highlights__title {
    font-family: 'Fraunces', Georgia, serif;
    font-size: clamp(1.5rem, 1rem + 2vw, 2rem);
    font-weight: 400;
    color: var(--color-olive);
    text-align: center;
    margin-bottom: 0.75rem;
  }

  .highlights__subtitle {
    font-size: clamp(1rem, 0.9375rem + 0.25vw, 1.0625rem);
    color: var(--color-olive);
    opacity: 0.75;
    text-align: center;
