---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import FloatingWhatsApp from '../components/FloatingWhatsApp.astro';
import SectionDivider from '../components/SectionDivider.astro';
import TreatmentCard from '../components/TreatmentCard.astro';
import { getCollection } from 'astro:content';

// Import all treatment images using Astro's asset system
import abhyangaImg from '../assets/images/abhyanga.webp';
import udvartanaImg from '../assets/images/udvartana.webp';
import navarakizhiImg from '../assets/images/navarakizhi.webp';
import patrapindaImg from '../assets/images/patrapinda.webp';
import pizhichilImg from '../assets/images/pizhichil.webp';
import shirodaraImg from '../assets/images/shirodara.webp';
import netratarpanaImg from '../assets/images/netratarpana.webp';
import karnapurnaImg from '../assets/images/karnapurna.webp';
import nasyaImg from '../assets/images/nasya.webp';
import hrdayaBastiImg from '../assets/images/hrdaya-basti.webp';
import cakraBastiImg from '../assets/images/cakra-basti.webp';
import greevaBastiImg from '../assets/images/greeva-basti.webp';
import katiBastiImg from '../assets/images/kati-basti.webp';
import januBastiImg from '../assets/images/janu-basti.webp';
import reflexioImg from '../assets/images/reflexio.webp';
import svedanaImg from '../assets/images/svedana.webp';
import oneOnOneImg from '../assets/images/one-on-one.webp';
import nusantaraExpImg from '../assets/images/nusantara-experience.webp';

const allTreatments = await getCollection('treatments');

// Image mapping for treatments (using Astro ImageMetadata)
const treatmentImages: Record<string, ImageMetadata> = {
  'Abhyanga': abhyangaImg,
  'Udvartana': udvartanaImg,
  'Navarakizhi': navarakizhiImg,
  'Patra Pinda Sveda': patrapindaImg,
  'Pizhichil': pizhichilImg,
  'Shirodhara': shirodaraImg,
  
  'Netra Tarpana': netratarpanaImg,
  'Karna Purana': karnapurnaImg,
  'Nasya': nasyaImg,
  'Hrdaya Basti': hrdayaBastiImg,
  'Cakra Basti': cakraBastiImg,
  'Greeva Basti': greevaBastiImg,
  'Kati Basti': katiBastiImg,
  'Janu Basti': januBastiImg,
  'Reflexology': reflexioImg,
  'Svedana': svedanaImg,
  'Ayurvedic One-on-One with Dr. Komang Sudarmi, BAMS., MS., PhD. (Ayurveda)': oneOnOneImg,
  'Ayurvedic Nusantara Experience': nusantaraExpImg,
};

// Separate signature treatments (special) from others
const signatureTreatments = allTreatments.filter(t => t.data.category === 'signature');
const regularTreatments = allTreatments.filter(t => t.data.category !== 'signature');

// Sort regular treatments alphabetically by name
regularTreatments.sort((a, b) => a.data.name.localeCompare(b.data.name));

// Collect all image URLs for prefetching
const allImageUrls = Object.values(treatmentImages).map(img => img.src);
---
---

<BaseLayout
  title="Ayurveda Therapy"
  description="The full treatment menu at Ayurvedic Wellness House — massage, Dhara, Basti, specialized therapies, and personalized Ayurvedic consultations."
  prefetchImages={allImageUrls}
>
  <Navbar />

  <main id="main-content">

    <!-- Page Header -->
    <section class="page-header section">
      <div class="container">
        <p class="page-eyebrow">Our Treatments</p>
        <h1 class="page-title">Ayurveda Therapy</h1>
        <p class="page-description">
          Every treatment is built on classical Ayurvedic principles and adapted to your specific needs. A consultation is required before your first session.
        </p>
      </div>
    </section>

    <!-- Signature Special Treatments (Top 2) -->
    {signatureTreatments.length > 0 && (
      <section class="special-treatments section">
        <div class="container">
          <h2 class="special-section-title">Signature Experiences</h2>
          <div class="special-grid">
            {signatureTreatments.map((treatment) => (
              <div class="special-card-wrapper">
                <TreatmentCard
                  name={treatment.data.name}
                  sanskritName={treatment.data.sanskritName}
                  description={treatment.data.description}
                  image={treatmentImages[treatment.data.name]}
                  category={treatment.data.category}
                  icon={treatment.data.icon}
                  featured={true}
                  link="/contact"
                />
              </div>
            ))}
          </div>
        </div>
      </section>
    )}

    <SectionDivider variant="ornate" />

    <!-- All Regular Treatments -->
    <section class="all-treatments section">
      <div class="container">
        <div class="treatments-grid">
          {regularTreatments.map((treatment, i) => (
            <TreatmentCard
              name={treatment.data.name}
              sanskritName={treatment.data.sanskritName}
              description={treatment.data.description}
              image={treatmentImages[treatment.data.name]}
              category={treatment.data.category}
              icon={treatment.data.icon}
              featured={false}
              link="/contact"
              index={i}
            />
          ))}
        </div>
      </div>
    </section>

    <SectionDivider variant="simple" />

    <!-- CTA Section -->
    <section class="therapy-cta section">
      <div class="container">
        <div class="cta-inner">
          <h2 class="cta-title">Begin with a Consultation</h2>
          <p class="cta-text">
            Every treatment plan starts here. We'll assess your constitution, discuss your health goals, and recommend a program tailored to you.
          </p>
          <div class="cta-actions">
            <a href="/contact" class="btn btn-primary">Book a Consultation</a>
            <a href="/packages" class="btn btn-outline">View Wellness Programs</a>
          </div>
        </div>
      </div>
    </section>

  </main>

  <Footer />
  <FloatingWhatsApp />
</BaseLayout>

<style>
  .page-header {
    background-color: var(--color-cream-base);
    padding-top: clamp(6rem, 12vw, 10rem);
    padding-bottom: clamp(1rem, 2vw, 2.5rem);
    text-align: center;
  }

  .all-treatments.section {
    padding-top: clamp(1.5rem, 3vw, 3rem);
  }

  .page-eyebrow {
    font-family: 'Karla', sans-serif;
    font-size: 0.8125rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-gold);
    margin-bottom: 1rem;
  }

  .page-title {
    font-family: 'Fraunces', Georgia, serif;
    font-size: clamp(2rem, 1.25rem + 3vw, 3.5rem);
    font-weight: 400;
    color: var(--color-olive);
    margin-bottom: 1.5rem;
  }

  .page-description {
    font-size: clamp(1rem, 0.9375rem + 0.25vw, 1.125rem);
    color: var(--color-olive);
    opacity: 0.75;
    max-width: 44ch;
    margin: 0 auto;
    line-height: 1.7;
  }

  /* Special Signature Section */
  .special-treatments {
    background: linear-gradient(
      to bottom,
      var(--color-cream-base) 0%,
      var(--color-cream-deep) 100%
    );
  }

  .special-section-title {
    font-family: 'Fraunces', Georgia, serif;
    font-size: clamp(1.25rem, 1rem + 1.5vw, 1.75rem);
    font-weight: 500;
    color: var(--color-olive);
    text-align: center;
    margin-bottom: 2rem;
    letter-spacing: 0.02em;
  }

  .special-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    max-width: 900px;
    margin: 0 auto;
  }

  @media (min-width: 768px) {
    .special-grid {
      grid-template-columns: repeat(2, 1fr);
      align-items: stretch;
    }
  }

  /* Special card wrapper with enhanced border */
  .special-card-wrapper {
    position: relative;
    display: flex;
  }

  .special-card-wrapper::before {
    content: '';
    position: absolute;
    inset: -3px;
    border: 2px solid var(--color-gold);
    pointer-events: none;
    z-index: 1;
  }

  .special-card-wrapper .treatment-card {
    border: 1px solid var(--color-gold);
    background-color: var(--color-cream-base);
    width: 100%;
    display: flex;
    flex-direction: column;
  }

  .special-card-wrapper .treatment-card__content {
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .special-card-wrapper .treatment-card__title {
    color: var(--color-olive);
  }

  .special-card-wrapper .treatment-card__description {
    color: var(--color-olive);
    flex: 1;
  }

  /* Treatments Grid */
  .treatments-grid {
    display: grid;
    grid-template-columns: repeat(1, 1fr);
    gap: 1.5rem;
    align-items: start;
  }

  @media (min-width: 640px) {
    .treatments-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .treatments-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* CTA */
  .cta-inner {
    text-align: center;
    max-width: 40rem;
    margin: 0 auto;
  }

  .cta-title {
    font-family: 'Fraunces', Georgia, serif;
    font-size: clamp(1.75rem, 1.25rem + 2vw, 2.5rem);
    font-weight: 400;
    color: var(--color-olive);
    margin-bottom: 1rem;
  }

  .cta-text {
    font-size: clamp(1rem, 0.9375rem + 0.25vw, 1.0625rem);
    color: var(--color-olive);
    opacity: 0.8;
    line-height: 1.7;
    margin-bottom: 2rem;
  }

  .cta-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1rem;
  }

  .btn-outline {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.875rem 2rem;
    font-family: 'Karla', sans-serif;
    font-size: 0.9375rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    border-radius: 0.125rem;
    border: 2px solid var(--color-sage);
    background-color: transparent;
    color: var(--color-olive);
    cursor: pointer;
    transition: all 0.25s ease;
    text-decoration: none;
  }

  .btn-outline:hover {
    background-color: var(--color-sage);
    color: white;
  }
</style>
