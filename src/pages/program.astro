---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import FloatingWhatsApp from '../components/FloatingWhatsApp.astro';
import SectionDivider from '../components/SectionDivider.astro';
import TreatmentCard from '../components/TreatmentCard.astro';
import { getCollection } from 'astro:content';

const allTreatments = await getCollection('treatments');
---

<BaseLayout
  title="Ayurveda Therapy"
  description="The full treatment menu at Ayurvedic Wellness House — massage, Dhara, Basti, specialized therapies, and personalized Ayurvedic consultations."
>
  <Navbar />

  <main id="main-content">

    <!-- Page Header -->
    <section class="page-header section">
      <div class="container">
        <p class="page-eyebrow">Our Treatments</p>
        <h1 class="page-title">Ayurveda Therapy</h1>
        <p class="page-description">
          Every treatment is built on classical Ayurvedic principles and adapted to your specific needs. A consultation is required before your first session.
        </p>
      </div>
    </section>

    <!-- All Treatments in One Section -->
    <section class="all-treatments section">
      <div class="container">
        <div class="treatments-grid">
          {allTreatments.map((treatment) => (
            <TreatmentCard
              name={treatment.data.name}
              sanskritName={treatment.data.sanskritName}
              description={treatment.data.description}
              category={treatment.data.category}
              icon={treatment.data.icon}
              featured={treatment.data.featured}
              link="/contact"
            />
          ))}
        </div>
      </div>
    </section>

    <SectionDivider variant="simple" />

    <!-- CTA Section -->
    <section class="therapy-cta section">
      <div class="container">
        <div class="cta-inner">
          <h2 class="cta-title">Begin with a Consultation</h2>
          <p class="cta-text">
            Every treatment plan starts here. We'll assess your constitution, discuss your health goals, and recommend a program tailored to you.
          </p>
          <div class="cta-actions">
            <a href="/contact" class="btn btn-primary">Book a Consultation</a>
            <a href="/packages" class="btn btn-outline">View Wellness Programs</a>
          </div>
        </div>
      </div>
    </section>

  </main>

  <Footer />
  <FloatingWhatsApp />
</BaseLayout>

<style>
  .page-header {
    background-color: var(--color-cream-base);
    padding-top: clamp(6rem, 12vw, 10rem);
    padding-bottom: clamp(1rem, 2vw, 2.5rem);
    text-align: center;
  }

  .all-treatments.section {
    padding-top: clamp(1.5rem, 3vw, 3rem);
  }

  .page-eyebrow {
    font-family: 'Karla', sans-serif;
    font-size: 0.8125rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-gold);
    margin-bottom: 1rem;
  }

  .page-title {
    font-family: 'Fraunces', Georgia, serif;
    font-size: clamp(2rem, 1.25rem + 3vw, 3.5rem);
    font-weight: 400;
    color: var(--color-olive);
    margin-bottom: 1.5rem;
  }

  .page-description {
    font-size: clamp(1rem, 0.9375rem + 0.25vw, 1.125rem);
    color: var(--color-olive);
    opacity: 0.75;
    max-width: 44ch;
    margin: 0 auto;
    line-height: 1.7;
  }

  /* Treatments Grid */
  .treatments-grid {
    display: grid;
    grid-template-columns: repeat(1, 1fr);
    gap: 1.5rem;
  }

  @media (min-width: 640px) {
    .treatments-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .treatments-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* CTA */
  .cta-inner {
    text-align: center;
    max-width: 40rem;
    margin: 0 auto;
  }

  .cta-title {
    font-family: 'Fraunces', Georgia, serif;
    font-size: clamp(1.75rem, 1.25rem + 2vw, 2.5rem);
    font-weight: 400;
    color: var(--color-olive);
    margin-bottom: 1rem;
  }

  .cta-text {
    font-size: clamp(1rem, 0.9375rem + 0.25vw, 1.0625rem);
    color: var(--color-olive);
    opacity: 0.8;
    line-height: 1.7;
    margin-bottom: 2rem;
  }

  .cta-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1rem;
  }

  .btn-outline {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.875rem 2rem;
    font-family: 'Karla', sans-serif;
    font-size: 0.9375rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    border-radius: 0.125rem;
    border: 2px solid var(--color-sage);
    background-color: transparent;
    color: var(--color-olive);
    cursor: pointer;
    transition: all 0.25s ease;
    text-decoration: none;
  }

  .btn-outline:hover {
    background-color: var(--color-sage);
    color: white;
  }
</style>
