---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import FloatingWhatsApp from '../components/FloatingWhatsApp.astro';
import SectionDivider from '../components/SectionDivider.astro';
// Using plain <img> tags with .src for Cloudflare Pages compatibility
import heroImg from '../assets/images/hero-desktop.webp';
---

<BaseLayout
  title="Ayurvedic Wellness House"
  description="Authentic Ayurvedic treatment combining traditional Indian medicine with Indonesian healing wisdom at Bali Silent Retreat."
>
  <Navbar />

  <main id="main-content">

    <!-- SECTION 1: Hero -->
    <section class="hero">
      <div class="hero__image" aria-hidden="true">
        <img
          src={heroImg.src}
          alt=""
          class="hero__bg-img"
          width={heroImg.width}
          height={heroImg.height}
          loading="eager"
          fetchpriority="high"
          decoding="async"
        />
      </div>
      <div class="hero__overlay" aria-hidden="true"></div>

      <div class="hero__content">
        <div class="container">
          <h1 class="hero__title">Where Ayurveda Meets the Healing Wisdom of Nusantara</h1>
          <div class="hero__actions">
            <a href="/contact" class="btn btn-primary">Book Consultation</a>
            <a href="/program" class="btn btn-secondary">Explore Programs</a>
          </div>
        </div>
      </div>
    </section>

    <!-- SECTION 2: Philosophy -->
    <section class="philosophy section">
      <div class="container">
        <div class="philosophy__inner">
          <h2 class="section-eyebrow">Our Philosophy</h2>
          <h3 class="philosophy__title">Ancient Ayurveda. Traditional Indonesian (Nusantara) Wisdom. One Personalized Healing Journey.</h3>
          <p class="philosophy__text">
            At Ayurvedic Wellness House, we believe that true healing comes from understanding each person as a whole — body, mind, and spirit. We bring together the time-tested wisdom of Classical Ayurveda and the rich healing heritage of Nusantara to create personalized wellness experiences that honor both traditions.
          </p>
        </div>
      </div>
    </section>

    <SectionDivider variant="simple" />

    <!-- SECTION 3: Why Choose Us -->
    <section class="why-us section section--alt">
      <div class="container">
        <h2 class="section-eyebrow">Why Choose Us</h2>
        <div class="why-us__grid">
          <div class="why-us__card">
            <div class="why-us__icon">
              <!-- Sprout Icon representing Authentic Ayurveda -->
              <svg viewBox="0 0 24 24" fill="none" stroke="#B8935A" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M7 20h10"></path>
                <path d="M12 20v-8"></path>
                <path d="M12 12a5 5 0 0 0-5-5H3"></path>
                <path d="M12 14a5 5 0 0 1 5-5h4"></path>
              </svg>
            </div>
            <h3 class="why-us__card-title">Authentic Ayurveda</h3>
            <p class="why-us__card-text">Led by Dr. Komang Sudarmi — a licensed Ayurvedic physician with over a decade of clinical practice.</p>
          </div>
          <div class="why-us__card">
            <div class="why-us__icon">
              <!-- Elegant Leaf Icon representing Nusantara Healing & Herbs -->
              <svg viewBox="0 0 24 24" fill="none" stroke="#B8935A" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 3.5 1 8a8.5 8.5 0 0 1-9 10z"></path>
                <path d="M19 2c-2.26 4.33-5.27 7.14-8 8"></path>
              </svg>
            </div>
            <h3 class="why-us__card-title">Traditional Indonesian (Nusantara) Healing</h3>
            <p class="why-us__card-text">Combining the healing wisdom of Indonesia's archipelago with authentic Ayurvedic protocols.</p>
          </div>
          <div class="why-us__card">
            <div class="why-us__icon">
              <!-- Heart Icon representing Personalized Programs -->
              <svg viewBox="0 0 24 24" fill="none" stroke="#B8935A" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"></path>
              </svg>
            </div>
            <h3 class="why-us__card-title">Personalized Programs</h3>
            <p class="why-us__card-text">Every treatment plan begins with a consultation to understand your unique constitution and needs.</p>
          </div>
          <div class="why-us__card">
            <div class="why-us__icon">
              <!-- Mountain Icon representing Natural Healing at Batukaru -->
              <svg viewBox="0 0 24 24" fill="none" stroke="#B8935A" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="m8 3 4 8 5-5 5 15H2L8 3z"></path>
                <path d="M12 21v-4"></path>
              </svg>
            </div>
            <h3 class="why-us__card-title">Natural Healing</h3>
            <p class="why-us__card-text">Set within Bali Silent Retreat — surrounded by rice fields, tropical forests, and Mount Batukaru.</p>
          </div>
        </div>
      </div>
    </section>

    <SectionDivider variant="simple" />

    <!-- SECTION 4: CTA -->
    <section class="home-cta section">
      <div class="container">
        <div class="home-cta__inner">
          <h2 class="home-cta__title">Begin Your Healing Journey</h2>
          <p class="home-cta__text">
            Whether you seek relief from specific health concerns, a deep detox, or simply a renewed sense of balance — we are here to guide you.
          </p>
          <div class="home-cta__actions">
            <a href="/contact" class="btn btn-primary">Book a Consultation</a>
            <a href="/packages" class="btn btn-outline">View Wellness Programs</a>
          </div>
        </div>
      </div>
    </section>

  </main>

  <Footer />
  <FloatingWhatsApp />
</BaseLayout>

<style>
  /* SECTION 1: Hero */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .hero__image {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero__bg-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(
      to bottom,
      rgba(20, 25, 15, 0.5) 0%,
      rgba(20, 25, 15, 0.75) 100%
    );
  }

  @media (min-width: 1024px) {
    .hero__overlay {
      background: linear-gradient(
        to right,
        rgba(20, 25, 15, 0.85) 0%,
        rgba(20, 25, 15, 0.6) 45%,
        rgba(20, 25, 15, 0.3) 100%
      );
    }
  }

  .hero__content {
    position: relative;
    z-index: 2;
    width: 100%;
    padding-top: 8rem;
    padding-bottom: 4rem;
  }

  .hero__title {
    font-family: 'Fraunces', Georgia, serif;
    font-size: clamp(2rem, 1.25rem + 4vw, 4rem);
    font-weight: 400;
    font-style: italic;
    color: var(--color-cream-base);
    line-height: 1.15;
    margin-bottom: 2rem;
    max-width: 18ch;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  /* SECTION 2: Philosophy */
  .philosophy {
    background-color: var(--color-cream-base);
  }

  .philosophy__inner {
    max-width: 52rem;
    margin: 0 auto;
    text-align: center;
  }

  .philosophy__title {
    font-family: 'Fraunces', Georgia, serif;
    font-size: clamp(1.5rem, 1rem + 2vw, 2.25rem);
    font-weight: 400;
    color: var(--color-olive);
    line-height: 1.3;
    margin-bottom: 1.5rem;
  }

  .philosophy__text {
    font-size: clamp(1rem, 0.9375rem + 0.25vw, 1.125rem);
    color: var(--color-olive);
    opacity: 0.85;
    line-height: 1.75;
  }

  /* SECTION 3: Why Choose Us */
  .why-us__grid {
    display: grid;
    grid-template-columns: repeat(1, 1fr);
    gap: 2rem;
    max-width: 64rem;
    margin: 0 auto;
  }

  @media (min-width: 640px) {
    .why-us__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .why-us__grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .why-us__card {
    text-align: center;
    padding: 1.5rem;
  }

  .why-us__icon {
    width: 3rem;
    height: 3rem;
    margin: 0 auto 1rem;
    color: var(--color-gold);
  }

  .why-us__icon svg {
    width: 100%;
    height: 100%;
  }

  .why-us__card-title {
    font-family: 'Fraunces', Georgia, serif;
    font-size: 1.125rem;
    font-weight: 500;
    color: var(--color-olive);
    margin-bottom: 0.5rem;
  }

  .why-us__card-text {
    font-size: 0.9375rem;
    color: var(--color-sage);
    line-height: 1.6;
    margin: 0;
  }

  /* SECTION 4: CTA */
  .home-cta {
    background-color: var(--color-cream-base);
  }

  .home-cta__inner {
    text-align: center;
    max-width: 40rem;
    margin: 0 auto;
  }

  .home-cta__title {
    font-family: 'Fraunces', Georgia, serif;
    font-size: clamp(1.75rem, 1.25rem + 2vw, 2.5rem);
    font-weight: 400;
    color: var(--color-olive);
    margin-bottom: 1rem;
  }

  .home-cta__text {
    font-size: clamp(1rem, 0.9375rem + 0.25vw, 1.0625rem);
    color: var(--color-olive);
    opacity: 0.8;
    line-height: 1.7;
    margin-bottom: 2rem;
  }

  .home-cta__actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1rem;
  }

  .btn-outline {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.875rem 2rem;
    font-family: 'Karla', sans-serif;
    font-size: 0.9375rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    border-radius: 0.125rem;
    border: 2px solid var(--color-sage);
    background-color: transparent;
    color: var(--color-olive);
    cursor: pointer;
    transition: all 0.25s ease;
    text-decoration: none;
  }

  .btn-outline:hover {
    background-color: var(--color-sage);
    color: white;
  }

  /* Section eyebrow */
  .section-eyebrow {
    font-family: 'Karla', sans-serif;
    font-size: 0.8125rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-gold);
    text-align: center;
    margin-bottom: 2rem;
  }

  /* Responsive */
  @media (max-width: 640px) {
    .hero {
      min-height: 85vh;
    }

    .hero__actions {
      flex-direction: column;
    }

    .hero__actions .btn {
      width: 100%;
    }
  }
</style>
