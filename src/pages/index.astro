---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import FloatingWhatsApp from '../components/FloatingWhatsApp.astro';
import SectionDivider from '../components/SectionDivider.astro';
import TreatmentCard from '../components/TreatmentCard.astro';

const featuredTreatments = [
  {
    name: 'Abhyanga',
    description: 'Warm herbal oil applied over the full body to ease muscle tension, support circulation, and calm the nervous system.',
    link: '/program#massage'
  },
  {
    name: 'Shirodhara',
    sanskritName: 'शिरोधारा',
    description: 'A continuous stream of warm herbal oil poured over the forehead to induce deep relaxation and mental stillness.',
    link: '/program#dhara'
  },
  {
    name: 'Svedana',
    sanskritName: 'स्वेदन',
    description: 'Whole-body herbal steam that warms the tissues, loosens muscles, and supports the body\'s detoxification process.',
    link: '/program#specialized'
  },
  {
    name: 'Reflexology',
    sanskritName: ' Padaabhyanga',
    description: 'Targeted pressure applied to specific points on the feet and hands to relieve tension and support circulation.',
    link: '/program#massage'
  },
  {
    name: 'Pizhichil',
    sanskritName: 'पिजिचिल',
    description: 'A continuous flow of warm medicated oil combined with gentle massage strokes.',
    link: '/program#massage'
  },
  {
    name: 'Ayurvedic One-on-One',
    description: 'A private consultation with an Ayurvedic practitioner to build a personalized wellness plan.',
    link: '/contact'
  }
];

const weeklyActivities = [
  {
    title: 'Ayurveda Introduction',
    time: 'Tuesdays, 2:00 PM',
    description: 'An introduction to core Ayurvedic principles for everyday health.'
  },
  {
    title: 'Water Purification',
    time: 'Fridays, 10:00 AM',
    description: 'A traditional hot-spring purification practice, guided by a traditional healer.'
  }
];
---

<BaseLayout
  title="Ayurvedic Wellness House"
  description="Authentic Ayurvedic treatment led by Dr. Komang Sudarmi, BAMS., MS., PhD (Ayurveda). Combining traditional Indian Ayurveda with Indonesian healing wisdom."
>
  <Navbar />

  <main id="main-content">

    <!-- SECTION 1: Hero -->
    <section class="hero">
      <!-- Hero Background Image -->
      <div class="hero__image" aria-hidden="true">
        <img
          src="/images/hero-desktop.webp"
          alt=""
          class="hero__bg-img"
          loading="eager"
        />
      </div>
      <!-- Dark overlay for text readability -->
      <div class="hero__overlay" aria-hidden="true"></div>

      <!-- Hero Content -->
      <div class="hero__content">
        <div class="container">
          <p class="hero__eyebrow">Ayurvedic Wellness House</p>
          <h1 class="hero__title">Heal With The Ancient Wisdom.</h1>
          <p class="hero__description">
            Authentic Ayurvedic treatment led by a licensed physician. Combining traditional Indian medicine with Indonesian healing wisdom, each program is built around your specific constitution and health goals.
          </p>
          <div class="hero__actions">
            <a href="/program" class="btn btn-primary">View Programs</a>
            <a href="/contact" class="btn btn-secondary">Get in Touch</a>
          </div>
        </div>
      </div>
    </section>

    <!-- SECTION 2: Philosophy Intro -->
    <section class="philosophy section">
      <div class="container">
        <div class="philosophy__inner">
          <h2 class="philosophy__title">Our Approach</h2>
          <div class="philosophy__content">
            <p>
              Ayurveda treats the whole person — body, mind, and spirit — not isolated symptoms. Every program begins with a consultation to understand your unique constitution (prakriti) and current imbalances (vikriti).
            </p>
            <p>
              We draw from classical Ayurvedic texts, herbal medicine, therapeutic touch, and lifestyle guidance — adapted through clinical experience and ongoing research to build a personalized plan for you.
            </p>
          </div>
        </div>
      </div>
    </section>

    <SectionDivider variant="simple" />

    <!-- SECTION 3: Founder Strip -->
    <section class="founder section section--alt">
      <div class="container">
        <div class="founder__inner">
          <!-- Portrait -->
          <div class="founder__portrait">
            <a href="/about" class="founder__portrait-link">
              <div class="founder__portrait-image">
                <div class="founder__portrait-placeholder">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                    <circle cx="8.5" cy="8.5" r="1.5"></circle>
                    <polyline points="21 15 16 10 5 21"></polyline>
                  </svg>
                </div>
                <span class="founder__portrait-label">[ dr-komang-portrait.webp — 800x1000px ]</span>
              </div>
            </a>
          </div>

          <!-- Bio -->
          <div class="founder__bio">
            <p class="founder__name">Dr. Komang Sudarmi, BAMS., MS., PhD (Ayurveda)</p>
            <p class="founder__role">Ayurvedic Physician, Researcher, Educator</p>
            <p class="founder__text">
              Trained in India and Europe, Dr. Komang brings over two decades of clinical practice to Ayurvedic Wellness House. Her approach integrates classical Ayurvedic protocols with contemporary health science — rooted in tradition, informed by evidence.
            </p>
            <a href="/about" class="founder__link">
              Learn more about Dr. Komang
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="5" y1="12" x2="19" y2="12"></line>
                <polyline points="12 5 19 12 12 19"></polyline>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </section>

    <SectionDivider />

    <!-- SECTION 4: Featured Treatments -->
    <section class="treatments section">
      <div class="container">
        <div class="treatments__header">
          <h2 class="treatments__title">Core Treatments</h2>
          <p class="treatments__subtitle">
            Each therapy serves a specific purpose. Programs are designed around your consultation findings.
          </p>
        </div>
        <div class="treatments__grid">
          {featuredTreatments.map((treatment) => (
            <TreatmentCard
              name={treatment.name}
              sanskritName={treatment.sanskritName}
              description={treatment.description}
              link={treatment.link}
              featured={true}
            />
          ))}
        </div>
        <div class="treatments__cta">
          <a href="/program" class="btn btn-outline">View All Treatments</a>
        </div>
      </div>
    </section>

    <SectionDivider variant="simple" />

    <!-- SECTION 5: Weekly Activities -->
    <section class="activities section section--alt">
      <div class="container">
        <div class="activities__header">
          <h2 class="activities__title">Weekly Sessions</h2>
        </div>
        <div class="activities__grid">
          {weeklyActivities.map((activity) => (
            <div class="schedule-card">
              <h3 class="schedule-card__title">{activity.title}</h3>
              <p class="schedule-card__time">{activity.time}</p>
              <p class="schedule-card__description">{activity.description}</p>
            </div>
          ))}
        </div>
        <p class="activities__location">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
            <circle cx="12" cy="10" r="3"></circle>
          </svg>
          Meet at the co-work space above the office.
        </p>
      </div>
    </section>

    <SectionDivider />

    <!-- SECTION 6: Guest Reflections -->
    <section class="testimonials section">
      <div class="container">
        <div class="testimonials__header">
          <h2 class="testimonials__title">Guest Reflections</h2>
        </div>
        <div class="testimonials__grid">
          <div class="testimonial-card">
            <p class="testimonial-card__quote">
              "After years of chronic tension, the Shirodhara session was the first time I felt genuine stillness. The difference was noticeable within minutes and held for days afterward."
            </p>
            <p class="testimonial-card__author">[Guest Name]</p>
          </div>
          <div class="testimonial-card">
            <p class="testimonial-card__quote">
              "The consultation was thorough in a way I'd never experienced elsewhere. Dr. Komang didn't just prescribe a treatment — she explained why."
            </p>
            <p class="testimonial-card__author">[Guest Name]</p>
          </div>
        </div>
      </div>
    </section>

    <!-- SECTION 7: Closing CTA -->
    <section class="closing section section--dark">
      <div class="container">
        <div class="closing__inner">
          <h2 class="closing__title">Begin Your Program</h2>
          <p class="closing__text">
            Every treatment plan starts with a consultation. We'll assess your constitution, discuss your health goals, and recommend a program tailored to you.
          </p>
          <div class="closing__actions">
            <a href="/contact" class="btn btn-secondary">Schedule a Consultation</a>
            <a href="/packages" class="btn btn-outline-white">View Packages</a>
          </div>
        </div>
      </div>
    </section>

  </main>

  <Footer />
  <FloatingWhatsApp />
</BaseLayout>

<style>
  /* ========================================
     SECTION 1: Hero
     ======================================== */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: flex-end;
    padding-bottom: clamp(4rem, 8vw, 8rem);
    overflow: hidden;
  }

  .hero__image {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero__bg-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(
      to bottom,
      rgba(20, 25, 15, 0.45) 0%,
      rgba(20, 25, 15, 0.8) 100%
    );
  }

  @media (min-width: 1024px) {
    .hero__overlay {
      background: linear-gradient(
        to right,
        rgba(20, 25, 15, 0.88) 0%,
        rgba(20, 25, 15, 0.65) 45%,
        rgba(20, 25, 15, 0.35) 100%
      );
    }
  }

  .hero__content {
    position: relative;
    z-index: 2;
    width: 100%;
    padding-top: 8rem;
  }

  .hero__eyebrow {
    font-family: 'Karla', sans-serif;
    font-size: 0.8125rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-gold);
    margin-bottom: 1rem;
  }

  .hero__title {
    font-family: 'Fraunces', Georgia, serif;
    font-size: clamp(2.5rem, 1.5rem + 4vw, 5rem);
    font-weight: 400;
    font-style: italic;
    color: var(--color-cream-base);
    line-height: 1.1;
    margin-bottom: 1.5rem;
    max-width: 14ch;
  }

  .hero__description {
    font-size: clamp(1rem, 0.9375rem + 0.25vw, 1.125rem);
    color: var(--color-cream-base);
    opacity: 0.9;
    max-width: 50ch;
    line-height: 1.7;
    margin-bottom: 2.5rem;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  /* ========================================
     SECTION 2: Philosophy
     ======================================== */
  .philosophy {
    background-color: var(--color-cream-base);
  }

  .philosophy__inner {
    max-width: 48rem;
    margin: 0 auto;
    text-align: center;
  }

  .philosophy__title {
    font-family: 'Fraunces', Georgia, serif;
    font-size: var(--text-h2);
    font-weight: 400;
    color: var(--color-olive);
    margin-bottom: 2rem;
  }

  .philosophy__content {
    text-align: left;
  }

  .philosophy__content p {
    font-size: clamp(1rem, 0.9375rem + 0.25vw, 1.0625rem);
    color: var(--color-olive);
    opacity: 0.85;
    line-height: 1.75;
  }

  /* ========================================
     SECTION 3: Founder
     ======================================== */
  .founder__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: center;
  }

  @media (min-width: 1024px) {
    .founder__inner {
      grid-template-columns: 5fr 7fr;
      gap: 5rem;
    }
  }

  .founder__portrait-link {
    display: block;
  }

  .founder__portrait-image {
    position: relative;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    background-color: var(--color-cream-base);
  }

  .founder__portrait-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-sage);
    opacity: 0.4;
  }

  .founder__portrait-placeholder svg {
    width: 4rem;
    height: 4rem;
  }

  .founder__portrait-label {
    position: absolute;
    bottom: 0.75rem;
    left: 50%;
    transform: translateX(-50%);
    font-size: 0.6875rem;
    color: var(--color-sage);
    background-color: rgba(255, 255, 255, 0.7);
    padding: 0.25rem 0.5rem;
    border-radius: 0.125rem;
    white-space: nowrap;
    font-family: 'Karla', monospace;
  }

  .founder__bio {
    order: -1;
  }

  @media (min-width: 1024px) {
    .founder__bio {
      order: 0;
    }
  }

  .founder__name {
    font-family: 'Fraunces', Georgia, serif;
    font-size: clamp(1.25rem, 1rem + 1vw, 1.5rem);
    font-weight: 500;
    color: var(--color-olive);
    margin-bottom: 0.25rem;
  }

  .founder__role {
    font-family: 'Karla', sans-serif;
    font-size: 0.8125rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-gold);
    margin-bottom: 1.5rem;
  }

  .founder__text {
    font-size: clamp(1rem, 0.9375rem + 0.25vw, 1.0625rem);
    color: var(--color-olive);
    opacity: 0.85;
    line-height: 1.75;
    margin-bottom: 1.5rem;
  }

  .founder__link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: 'Karla', sans-serif;
    font-size: 0.875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-sage);
    transition: color 0.2s ease;
  }

  .founder__link:hover {
    color: var(--color-olive);
  }

  .founder__link svg {
    width: 1rem;
    height: 1rem;
    transition: transform 0.2s ease;
  }

  .founder__link:hover svg {
    transform: translateX(4px);
  }

  /* ========================================
     SECTION 4: Featured Treatments
     ======================================== */
  .treatments {
    background-color: var(--color-cream-base);
  }

  .treatments__header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .treatments__title {
    font-family: 'Fraunces', Georgia, serif;
    font-size: var(--text-h2);
    font-weight: 400;
    color: var(--color-olive);
    margin-bottom: 1rem;
  }

  .treatments__subtitle {
    font-size: clamp(1rem, 0.9375rem + 0.25vw, 1.0625rem);
    color: var(--color-olive);
    opacity: 0.75;
    max-width: 40ch;
    margin: 0 auto;
  }

  .treatments__grid {
    display: grid;
    grid-template-columns: repeat(1, 1fr);
    gap: 1.5rem;
  }

  @media (min-width: 640px) {
    .treatments__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .treatments__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .treatments__cta {
    text-align: center;
    margin-top: 3rem;
  }

  .btn-outline {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.875rem 2rem;
    font-family: 'Karla', sans-serif;
    font-size: 0.9375rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    border-radius: 0.125rem;
    border: 2px solid var(--color-sage);
    background-color: transparent;
    color: var(--color-olive);
    cursor: pointer;
    transition: all 0.25s ease;
    text-decoration: none;
  }

  .btn-outline:hover {
    background-color: var(--color-sage);
    color: white;
  }

  /* ========================================
     SECTION 5: Activities
     ======================================== */
  .activities__header {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .activities__title {
    font-family: 'Fraunces', Georgia, serif;
    font-size: var(--text-h2);
    font-weight: 400;
    color: var(--color-olive);
  }

  .activities__grid {
    display: grid;
    grid-template-columns: repeat(1, 1fr);
    gap: 1.5rem;
    max-width: 48rem;
    margin: 0 auto 2rem;
  }

  @media (min-width: 640px) {
    .activities__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .activities__location {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    font-family: 'Karla', sans-serif;
    font-size: 0.875rem;
    color: var(--color-sage);
    text-align: center;
  }

  .activities__location svg {
    width: 1.125rem;
    height: 1.125rem;
    color: var(--color-gold);
  }

  /* ========================================
     SECTION 6: Testimonials
     ======================================== */
  .testimonials {
    background-color: var(--color-cream-base);
  }

  .testimonials__header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .testimonials__title {
    font-family: 'Fraunces', Georgia, serif;
    font-size: var(--text-h2);
    font-weight: 400;
    color: var(--color-olive);
  }

  .testimonials__grid {
    display: grid;
    grid-template-columns: repeat(1, 1fr);
    gap: 2rem;
    max-width: 56rem;
    margin: 0 auto;
  }

  @media (min-width: 768px) {
    .testimonials__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* ========================================
     SECTION 7: Closing CTA
     ======================================== */
  .closing__inner {
    text-align: center;
    max-width: 40rem;
    margin: 0 auto;
  }

  .closing__title {
    font-family: 'Fraunces', Georgia, serif;
    font-size: clamp(1.75rem, 1.25rem + 2vw, 2.5rem);
    font-weight: 400;
    font-style: italic;
    color: var(--color-cream-base);
    margin-bottom: 1rem;
  }

  .closing__text {
    font-size: clamp(1rem, 0.9375rem + 0.25vw, 1.0625rem);
    color: var(--color-cream-base);
    opacity: 0.85;
    margin-bottom: 2rem;
    line-height: 1.7;
  }

  .closing__actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1rem;
  }

  .btn-outline-white {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.875rem 2rem;
    font-family: 'Karla', sans-serif;
    font-size: 0.9375rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    border-radius: 0.125rem;
    border: 2px solid var(--color-cream-base);
    background-color: transparent;
    color: var(--color-cream-base);
    cursor: pointer;
    transition: all 0.25s ease;
    text-decoration: none;
  }

  .btn-outline-white:hover {
    background-color: var(--color-cream-base);
    color: var(--color-olive);
  }

  /* ========================================
     Responsive Adjustments
     ======================================== */
  @media (max-width: 640px) {
    .hero {
      min-height: 85vh;
    }

    .hero__actions {
      flex-direction: column;
    }

    .hero__actions .btn {
      width: 100%;
    }
  }
</style>
