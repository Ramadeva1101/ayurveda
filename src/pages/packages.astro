    durationLine2: '(different room different prices)',
    price: 'IDR 43,000,000',
    highlight: 'Our most comprehensive program.',
    includes: [
      'Initial Comprehensive Ayurvedic One on One',
      'Nutritional drink',
      'Personalized Ayurvedic Therapy (18 Therapy)',
      'Javanese point pressure (Nusantara Therapy – 3 times)',
      'Pancha Karma Program with consultation (Three times)',
      'Ayurvedic activities every week hosted at Bali Silent Retreat (Introduction ayurveda, water purification)',
      'Final Ayurvedic One on One',
    ],
    excludes: [
      'Accommodation',
      'Meals',
      'Transportation',
    ],
    badge: null,
    featured: false,
  },
