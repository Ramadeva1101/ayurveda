    ],
    badge: null,
    featured: false,
  },
  {
    name: '5-Day Pancha Karma Nusantara Program',
    duration: '5 Days (accommodation and day pass included: make booking directly @ https://www.balisilentretreat.com/)',
    durationLine2: '(different room different prices)',
    price: 'IDR 9,800,000',
    highlight: 'Initial Pancha Karma experience.',
    includes: [
      'Initial Comprehensive Ayurvedic One on One',
      'Nutritional drink',
