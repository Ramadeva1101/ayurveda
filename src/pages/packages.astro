---

<BaseLayout
  title="Our Wellness Programs"
  description="Treatment programs at Ayurvedic Wellness House — from one-day experiences to 21-day classical Panchakarma, all built on classical Ayurvedic and Nusantara healing principles."
>
  <Navbar />

  <main id="main-content">

    <!-- Page Header -->
    <section class="page-header section">
      <div class="container">
        <p class="page-eyebrow">Rejuvenation &amp; AYURVEDIC Programs</p>
        <h1 class="page-title">Our Wellness Programs</h1>
        <p class="page-description">
          Each program is designed around a specific wellness goal. All programs include consultation, personalized treatments, and follow-up support. Operating from 9am–5pm. Prior booking is required.
        </p>
      </div>
    </section>

    <!-- Package Cards -->
    <section class="packages section">
      <div class="container">
        <div class="packages-grid">

          {packages.map((pkg) => (
            <article class:list={['package-card', { 'package-card--featured': pkg.featured }]}>
              {pkg.badge && (
                <div class="package-badge">{pkg.badge}</div>
              )}
              <div class="package-header">
                <h2 class="package-name">{pkg.name}</h2>
              </div>
              <div class="package-duration">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="12" cy="12" r="10"></circle>
                  <polyline points="12 6 12 12 16 14"></polyline>
                </svg>
                <span>
                  {pkg.duration}
                  {pkg.durationLine2 && <span class="duration-line2">{pkg.durationLine2}</span>}
                </span>
              </div>
              <div class="package-price">
                <span class="price-amount">{pkg.price}</span>
              </div>
              <div class="package-highlight">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
                </svg>
                <span>{pkg.highlight}</span>
              </div>
              <div class="package-includes">
                <p class="includes-label">Includes</p>
                <ul class="includes-list">
                  {pkg.includes.map((item) => (
                    <li>
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="20 6 9 17 4 12"></polyline>
                      </svg>
                      <span>{item}</span>
                    </li>
                  ))}
                </ul>
              </div>
              {pkg.excludes && pkg.excludes.length > 0 && (
                <div class="package-excludes">
                  <p class="excludes-label">Excludes</p>
                  <ul class="excludes-list">
                    {pkg.excludes.map((item) => (
                      <li>
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                          <line x1="18" y1="6" x2="6" y2="18"></line>
                          <line x1="6" y1="6" x2="18" y2="18"></line>
                        </svg>
                        <span>{item}</span>
                      </li>
                    ))}
                  </ul>
                </div>
              )}
              <a href="/contact" class:list={['package-btn', { 'btn': true, 'btn-primary': pkg.featured, 'btn-outline': !pkg.featured }]}>Book Now</a>
            </article>
          ))}

        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="packages-cta section section--dark">
      <div class="container">
        <div class="cta-inner">
          <h2 class="cta-title">Ready to Begin?</h2>
          <p class="cta-text">
            Not sure which package is right for you? A consultation can help determine the best program for your needs and goals.
          </p>
          <div class="cta-actions">
            <a href="/contact" class="btn btn-secondary">Book a Consultation</a>
            <a href="/program" class="btn-outline-white">View All Treatments</a>
          </div>
        </div>
      </div>
    </section>

  </main>

  <Footer />
  <FloatingWhatsApp />
</BaseLayout>

<style>
  .page-header {
    background-color: var(--color-cream-base);
    padding-top: clamp(6rem, 12vw, 10rem);
    padding-bottom: clamp(1rem, 2vw, 2.5rem);
    text-align: center;
  }

  .packages.section {
    padding-top: clamp(1.5rem, 3vw, 3rem);
  }

  .page-eyebrow {
    font-family: 'Karla', sans-serif;
    font-size: 0.8125rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-gold);
    margin-bottom: 1rem;
  }

  .page-title {
    font-family: 'Fraunces', Georgia, serif;
    font-size: clamp(2rem, 1.25rem + 3vw, 3.5rem);
    font-weight: 400;
    color: var(--color-olive);
    margin-bottom: 1.5rem;
  }

  .page-description {
    font-size: clamp(1rem, 0.9375rem + 0.25vw, 1.125rem);
    color: var(--color-olive);
    opacity: 0.75;
    max-width: 50ch;
    margin: 0 auto;
    line-height: 1.7;
  }

  /* Packages Grid */
  .packages-grid {
    display: grid;
    grid-template-columns: repeat(1, 1fr);
    gap: 2rem;
    align-items: start;
  }

  @media (min-width: 640px) {
    .packages-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .packages-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* Package Card */
  .package-card {
    position: relative;
    background-color: var(--color-cream-base);
    border: 1px solid var(--color-cream-deep);
    padding: 2rem;
    display: flex;
    flex-direction: column;
    transition: all 0.3s ease;
  }

  .package-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(63, 74, 50, 0.08);
  }

  /* Featured card — Gold border */
  .package-card--featured {
    border: 2px solid var(--color-gold);
  }

  .package-card--featured:hover {
    box-shadow: 0 16px 48px rgba(63, 74, 50, 0.12);
  }

  /* Badge */
  .package-badge {
    position: absolute;
    top: -0.75rem;
    left: 50%;
    transform: translateX(-50%);
    font-family: 'Karla', sans-serif;
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 0.25rem 0.875rem;
    border-radius: 9999px;
    background-color: var(--color-gold);
    color: white;
    white-space: nowrap;
  }

  .package-header {
    margin-bottom: 1rem;
  }

  .package-name {
    font-family: 'Fraunces', Georgia, serif;
    font-size: clamp(1.125rem, 1rem + 1vw, 1.375rem);
    font-weight: 500;
    color: var(--color-olive);
    line-height: 1.3;
  }

  /* Duration */
  .package-duration {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    font-family: 'Karla', sans-serif;
    font-size: 0.8125rem;
    color: var(--color-sage);
    margin-bottom: 0.75rem;
    line-height: 1.5;
  }

  .package-duration svg {
    width: 0.875rem;
    height: 0.875rem;
    flex-shrink: 0;
    color: var(--color-gold);
    margin-top: 0.15rem;
  }

  .duration-line2 {
    display: block;
  }

  /* Price */
  .package-price {
    margin-bottom: 1rem;
  }

  .price-amount {
    font-family: 'Fraunces', Georgia, serif;
    font-size: clamp(1.25rem, 1rem + 1.5vw, 1.75rem);
    font-weight: 500;
    color: var(--color-olive);
  }

  /* Highlight */
  .package-highlight {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    padding: 0.75rem;
    background-color: rgba(184, 147, 90, 0.08);
    border-left: 2px solid var(--color-gold);
    margin-bottom: 1.25rem;
    font-size: 0.875rem;
    font-style: italic;
    color: var(--color-olive);
    line-height: 1.4;
  }

  .package-highlight svg {
    width: 0.875rem;
    height: 0.875rem;
    flex-shrink: 0;
    color: var(--color-gold);
    margin-top: 0.125rem;
  }

  .package-highlight span {
    color: var(--color-olive);
  }

  /* Includes */
  .package-includes {
    margin-bottom: 1.25rem;
  }

  .includes-label,
  .excludes-label {
    font-family: 'Karla', sans-serif;
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-olive);
    opacity: 0.5;
    margin-bottom: 0.625rem;
  }

  .includes-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .includes-list li {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: var(--color-olive);
    line-height: 1.4;
  }

  .includes-list li svg {
    width: 0.75rem;
    height: 0.75rem;
    flex-shrink: 0;
    margin-top: 0.1875rem;
    color: var(--color-sage);
  }

  /* Excludes */
  .package-excludes {
    margin-bottom: 1.5rem;
    padding-top: 1rem;
    border-top: 1px solid var(--color-cream-deep);
  }

  .excludes-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .excludes-list li {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    font-size: 0.8125rem;
    color: var(--color-sage);
    opacity: 0.75;
    line-height: 1.4;
  }

  .excludes-list li svg {
    width: 0.75rem;
    height: 0.75rem;
    flex-shrink: 0;
    margin-top: 0.1875rem;
    opacity: 0.6;
  }

  /* Buttons */
  .package-btn {
    width: 100%;
    justify-content: center;
    text-decoration: none;
  }

  /* CTA Section */
  .packages-cta {
    text-align: center;
  }

  .cta-inner {
    max-width: 40rem;
    margin: 0 auto;
  }

  .cta-title {
    font-family: 'Fraunces', Georgia, serif;
    font-size: clamp(1.75rem, 1.25rem + 2vw, 2.5rem);
    font-weight: 400;
    font-style: italic;
    color: var(--color-cream-base);
    margin-bottom: 1rem;
  }

  .cta-text {
    font-size: clamp(1rem, 0.9375rem + 0.25vw, 1.0625rem);
    color: var(--color-cream-base);
    opacity: 0.85;
    line-height: 1.7;
    margin-bottom: 2rem;
  }

  .cta-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1rem;
  }

  .btn-outline-white {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.875rem 2rem;
    font-family: 'Karla', sans-serif;
    font-size: 0.9375rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    border-radius: 0.125rem;
    border: 2px solid var(--color-cream-base);
    background-color: transparent;
    color: var(--color-cream-base);
    cursor: pointer;
    transition: all 0.25s ease;
    text-decoration: none;
  }

  .btn-outline-white:hover {
    background-color: var(--color-cream-base);
    color: var(--color-olive);
  }

  @media (max-width: 640px) {
    .package-card {
      padding: 1.5rem;
    }
  }
</style>
