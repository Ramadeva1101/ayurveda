  },
  {
    name: '7-Day Pancha Karma Nusantara Program',
    duration: '7 Days (accommodation and day pass included: make booking directly @ https://www.balisilentretreat.com/)',
    durationLine2: '(different room different prices)',
    price: 'IDR 15,000,000',
    highlight: 'Our most popular program.',
