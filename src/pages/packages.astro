      'Transportation',
    ],
    badge: null,
    featured: false,
  },
  {
    name: '3-Day Ayurvedic Nusantara Program',
    duration: '3 Days (accommodation and day pass included: make booking directly @ https://www.balisilentretreat.com/)',
    durationLine2: '(different room different prices)',
    price: 'IDR 5,900,000',
    highlight: 'Perfect introduction to Ayurvedic healing.',
