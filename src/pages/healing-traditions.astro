---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import FloatingWhatsApp from '../components/FloatingWhatsApp.astro';
import SectionDivider from '../components/SectionDivider.astro';
---

<BaseLayout
  title="Healing Traditions"
  description="Where Two Ancient Healing Traditions Meet — Ayurveda and Nusantara Traditional Healing combined for personalized wellness."
>
  <Navbar />

  <main id="main-content">

    <!-- Hero -->
    <section class="page-header section">
      <div class="container">
        <h1 class="page-title">Where Two Ancient Healing Traditions Meet</h1>
        <p class="page-subtitle">Ayurveda &amp; Nusantara</p>
      </div>
    </section>

    <!-- Intro -->
    <section class="intro section">
      <div class="container">
        <div class="intro__inner">
          <p class="intro__lead">
            At Ayurvedic Wellness House, we bring together the timeless wisdom of Classical Ayurveda and the rich heritage of Nusantara Traditional Healing to create a personalized wellness experience unlike any other.
          </p>
        </div>
      </div>
    </section>

    <SectionDivider />

    <!-- What is Ayurveda -->
    <section class="tradition section section--alt">
      <div class="container">
        <div class="tradition__inner">
          <div class="tradition__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
            </svg>
          </div>
          <h2 class="tradition__title">What is Ayurveda?</h2>
          <div class="tradition__content">
            <p>
              Ayurveda, meaning <em>"The Science of Life,"</em> is a traditional medical system from India with over 5,000 years of history. It focuses on restoring balance in the body through personalized consultation, herbal medicine, therapeutic treatments, nutrition, and healthy lifestyle practices.
            </p>
            <p>
              Rather than treating symptoms alone, Ayurveda aims to support the body's natural ability to heal and maintain long-term well-being.
            </p>
          </div>
        </div>
      </div>
    </section>

    <SectionDivider variant="simple" />

    <!-- What is Nusantara Traditional Healing -->
    <section class="tradition section">
      <div class="container">
        <div class="tradition__inner">
          <div class="tradition__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"></circle>
              <path d="M12 8c-2.21 0-4 1.79-4 4s1.79 4 4 4 4-1.79 4-4-1.79-4-4-4"></path>
            </svg>
          </div>
          <h2 class="tradition__title">What is Nusantara Traditional Healing?</h2>
          <div class="tradition__content">
            <p>
              Nusantara Traditional Healing is Indonesia's traditional healing heritage, developed over generations using local herbs, therapeutic bodywork, and natural healing practices.
            </p>
            <p>
              It emphasizes harmony between the body, mind, nature, and spirit, reflecting the diverse wisdom found throughout the Indonesian archipelago.
            </p>
          </div>
        </div>
      </div>
    </section>

    <SectionDivider />

    <!-- Why Combine -->
    <section class="combine section section--alt">
      <div class="container">
        <div class="combine__inner">
          <h2 class="combine__title">Why Combine Ayurveda &amp; Nusantara?</h2>
          <p class="combine__intro">Although they come from different cultures, both healing traditions share the same philosophy:</p>
          <ul class="combine__list">
            <li>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
              Treat the whole person, not just the symptoms
            </li>
            <li>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
              Restore balance naturally
            </li>
            <li>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
              Use herbs and therapeutic touch
            </li>
            <li>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
              Support the body's own healing process
            </li>
            <li>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
              Encourage a healthy lifestyle for lasting wellness
            </li>
          </ul>
          <p class="combine__closing">
            By combining these complementary traditions, we create a unique healing experience that is both authentic and deeply personalized.
          </p>
        </div>
      </div>
    </section>

    <SectionDivider variant="simple" />

    <!-- CTA -->
    <section class="closing section">
      <div class="container">
        <div class="closing__inner">
          <h2 class="closing__title">Discover a Healing Experience Where Ancient Wisdom Meets the Heart of Indonesia</h2>
          <div class="closing__actions">
            <a href="/contact" class="btn btn-primary">Book a Consultation</a>
            <a href="/packages" class="btn btn-outline">View Wellness Programs</a>
          </div>
        </div>
      </div>
    </section>

  </main>

  <Footer />
  <FloatingWhatsApp />
</BaseLayout>

<style>
  .page-header {
    background-color: var(--color-cream-base);
    padding-top: clamp(6rem, 12vw, 10rem);
    padding-bottom: clamp(1rem, 2vw, 2.5rem);
    text-align: center;
  }

  .intro.section {
    padding-top: clamp(1.5rem, 3vw, 3rem);
  }

  .page-title {
    font-family: 'Fraunces', Georgia, serif;
    font-size: clamp(2rem, 1.25rem + 3vw, 3.5rem);
    font-weight: 400;
    color: var(--color-olive);
    margin-bottom: 0.5rem;
    max-width: 20ch;
    margin-left: auto;
    margin-right: auto;
    line-height: 1.2;
  }

  .page-subtitle {
    font-family: 'Karla', sans-serif;
    font-size: 1rem;
    color: var(--color-sage);
    font-weight: 500;
    letter-spacing: 0.05em;
  }

  /* Intro */
  .intro__inner {
    max-width: 48rem;
    margin: 0 auto;
    text-align: center;
  }

  .intro__lead {
    font-family: 'Fraunces', Georgia, serif;
    font-size: clamp(1.25rem, 1rem + 1vw, 1.5rem);
    font-weight: 400;
    font-style: italic;
    color: var(--color-olive);
    line-height: 1.5;
  }

  /* Tradition */
  .tradition__inner {
    max-width: 44rem;
    margin: 0 auto;
  }

  .tradition__icon {
    width: 3.5rem;
    height: 3.5rem;
    margin: 0 auto 1.5rem;
    color: var(--color-gold);
  }

  .tradition__icon svg {
    width: 100%;
    height: 100%;
  }

  .tradition__title {
    font-family: 'Fraunces', Georgia, serif;
    font-size: clamp(1.5rem, 1rem + 2vw, 2rem);
    font-weight: 400;
    color: var(--color-olive);
    text-align: center;
    margin-bottom: 1.5rem;
  }

  .tradition__content p {
    font-size: clamp(1rem, 0.9375rem + 0.25vw, 1.0625rem);
    color: var(--color-olive);
    opacity: 0.85;
    line-height: 1.75;
  }

  /* Combine */
  .combine__inner {
    max-width: 40rem;
    margin: 0 auto;
    text-align: center;
  }

  .combine__title {
    font-family: 'Fraunces', Georgia, serif;
    font-size: clamp(1.5rem, 1rem + 2vw, 2rem);
    font-weight: 400;
    color: var(--color-olive);
    margin-bottom: 1rem;
  }

  .combine__intro {
    font-size: clamp(1rem, 0.9375rem + 0.25vw, 1.0625rem);
    color: var(--color-olive);
    opacity: 0.8;
    margin-bottom: 2rem;
  }

  .combine__list {
    list-style: none;
    padding: 0;
    margin: 0 0 2rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    text-align: left;
  }

  .combine__list li {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    font-size: clamp(1rem, 0.9375rem + 0.25vw, 1.0625rem);
    color: var(--color-olive);
    line-height: 1.5;
  }

  .combine__list svg {
    width: 1.25rem;
    height: 1.25rem;
    flex-shrink: 0;
    color: var(--color-gold);
    margin-top: 0.125rem;
  }

  .combine__closing {
    font-size: clamp(1rem, 0.9375rem + 0.25vw, 1.0625rem);
    color: var(--color-olive);
    opacity: 0.85;
    font-style: italic;
    line-height: 1.7;
  }

  /* Closing */
  .closing__inner {
    text-align: center;
    max-width: 40rem;
    margin: 0 auto;
  }

  .closing__title {
    font-family: 'Fraunces', Georgia, serif;
    font-size: clamp(1.5rem, 1rem + 2vw, 2rem);
    font-weight: 400;
    font-style: italic;
    color: var(--color-olive);
    margin-bottom: 2rem;
    line-height: 1.3;
  }

  .closing__actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1rem;
  }

  .btn-outline {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.875rem 2rem;
    font-family: 'Karla', sans-serif;
    font-size: 0.9375rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    border-radius: 0.125rem;
    border: 2px solid var(--color-sage);
    background-color: transparent;
    color: var(--color-olive);
    cursor: pointer;
    transition: all 0.25s ease;
    text-decoration: none;
  }

  .btn-outline:hover {
    background-color: var(--color-sage);
    color: white;
  }
</style>
