---
const navItems = [
  { label: 'Home', href: '/' },
  { label: 'About', href: '/about' },
  { label: 'Program', href: '/program' },
  { label: 'Packages', href: '/packages' },
  { label: 'Contact', href: '/contact' },
];

const currentYear = new Date().getFullYear();
---

<footer class="footer">
  <div class="container">
    <div class="footer-grid">
      <!-- Brand Column -->
      <div class="footer-brand">
        <a href="/" class="footer-logo" aria-label="Ayurvedic Wellness House">
          <img
            src="/images/logo.png"
            alt="Ayurvedic Wellness House"
            class="footer-logo-img"
            onerror="this.onerror=null; this.src='/images/logo.svg';"
          />
        </a>
        <p class="footer-tagline">
          Authentic Ayurvedic treatment combining traditional Indian medicine with Indonesian healing wisdom.
        </p>
        <!-- Social Links -->
        <div class="footer-social">
          <!-- TODO: replace with the client's actual Instagram URL -->
          <a href="https://instagram.com/ayurvedicwellnesshouse" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
              <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
            </svg>
          </a>
          <!-- TODO: add Facebook URL if needed -->
        </div>
      </div>

      <!-- Quick Links -->
      <div class="footer-links">
        <h4 class="footer-heading">Navigate</h4>
        <ul class="footer-menu">
          {navItems.map((item) => (
            <li>
              <a href={item.href} class="footer-link">{item.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Services -->
      <div class="footer-services">
        <h4 class="footer-heading">Our Treatments</h4>
        <ul class="footer-menu">
          <li><a href="/program#massage" class="footer-link">Abhyanga Massage</a></li>
          <li><a href="/program#dhara" class="footer-link">Shirodhara</a></li>
          <li><a href="/program#basti" class="footer-link">Kativasti</a></li>
          <li><a href="/program#specialized" class="footer-link">Specialized Therapies</a></li>
          <li><a href="/packages" class="footer-link">Wellness Packages</a></li>
        </ul>
      </div>

      <!-- Contact Info -->
      <div class="footer-contact">
        <h4 class="footer-heading">Get in Touch</h4>
        <address class="footer-address">
          <!-- TODO: replace with the client's real address -->
          <p class="footer-contact-item">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
              <circle cx="12" cy="10" r="3"></circle>
            </svg>
            Accommodation Homestage at Bali Silent Retreat<br />Bali, Indonesia.
          </p>
          <!-- TODO: replace with the client's real WhatsApp number -->
          <p class="footer-contact-item">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
            </svg>
            +62 859-2646-1359
          </p>
          <!-- TODO: replace with the client's real email -->
          <p class="footer-contact-item">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
              <polyline points="22,6 12,13 2,6"></polyline>
            </svg>
            ayurvedicwellnesshouse@gmail.com
          </p>
        </address>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="footer-bottom">
      <div class="footer-divider"></div>
      <p class="footer-copyright">
        &copy; {currentYear} Ayurvedic Wellness House. All rights reserved.
      </p>
      <p class="footer-credit">
        Led by <strong>Dr. Komang Sudarmi, BAMS., MS., PhD (Ayurveda)</strong>
      </p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background-color: var(--color-cream-deep);
    padding-top: 4rem;
    padding-bottom: 2rem;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: repeat(1, 1fr);
    gap: 2rem;
  }

  @media (min-width: 768px) {
    .footer-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .footer-grid {
      grid-template-columns: 2fr 1fr 1fr 1.5fr;
    }
  }

  .footer-brand {
    margin-bottom: 1rem;
  }

  .footer-logo {
    display: inline-block;
    margin-bottom: 1rem;
  }

  .footer-logo-img {
    height: 3.5rem;
    width: auto;
  }

  .footer-tagline {
    font-size: 0.9375rem;
    color: var(--color-sage);
    line-height: 1.6;
    margin-bottom: 1.5rem;
  }

  .footer-social {
    display: flex;
    gap: 1rem;
  }

  .footer-social a {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border: 1px solid var(--color-sage);
    border-radius: 50%;
    color: var(--color-olive);
    transition: all 0.2s ease;
  }

  .footer-social a:hover {
    background-color: var(--color-olive);
    border-color: var(--color-olive);
    color: white;
  }

  .footer-social svg {
    width: 1.125rem;
    height: 1.125rem;
  }

  .footer-heading {
    font-family: 'Fraunces', Georgia, serif;
    font-size: 1.125rem;
    font-weight: 500;
    color: var(--color-olive);
    margin-bottom: 1.5rem;
  }

  .footer-menu {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .footer-link {
    font-size: 0.9375rem;
    color: var(--color-sage);
    transition: color 0.2s ease;
  }

  .footer-link:hover {
    color: var(--color-olive);
  }

  .footer-address {
    font-style: normal;
  }

  .footer-contact-item {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    font-size: 0.9375rem;
    color: var(--color-sage);
    margin-bottom: 1rem;
  }

  .footer-contact-item svg {
    flex-shrink: 0;
    width: 1.125rem;
    height: 1.125rem;
    margin-top: 0.125rem;
    color: var(--color-gold);
  }

  .footer-bottom {
    margin-top: 3rem;
    padding-top: 2rem;
    text-align: center;
  }

  .footer-divider {
    height: 1px;
    background-color: var(--color-gold);
    opacity: 0.3;
    margin-bottom: 1.5rem;
  }

  .footer-copyright {
    font-size: 0.8125rem;
    color: var(--color-sage);
    margin-bottom: 0.5rem;
  }

  .footer-credit {
    font-size: 0.8125rem;
    color: var(--color-olive);
  }

  .footer-credit strong {
    font-family: 'Fraunces', Georgia, serif;
    font-weight: 500;
  }
</style>
