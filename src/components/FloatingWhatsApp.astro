---
interface Props {
  phoneNumber?: string;
  message?: string;
}

const {
  phoneNumber = '6285926461359',
  message = 'Halo%20saya%20ingin%20bertanya%20tentang%20treatment'
} = Astro.props;

const waUrl = `https://wa.me/${phoneNumber}?text=${message}`;
---

<a
  href={waUrl}
  target="_blank"
  rel="noopener noreferrer"
  aria-label="Chat via WhatsApp"
  class="wa-float"
  id="wa-float-btn"
>
  <!-- Idle pulse ring -->
  <span class="wa-pulse" aria-hidden="true"></span>

  <!-- Main button -->
  <span class="wa-btn">
    <!-- WhatsApp icon -->
    <svg
      class="wa-icon"
      viewBox="0 0 24 24"
      fill="currentColor"
      xmlns="http://www.w3.org/2000/svg"
    >
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
    </svg>
  </span>

  <!-- Ripple container -->
  <span class="wa-ripple" aria-hidden="true"></span>
</a>

<script>
  import gsap from 'gsap';

  const waBtn = document.getElementById('wa-float-btn');
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');

  if (waBtn && !prefersReducedMotion.matches) {
    // Click animation
    waBtn.addEventListener('click', (e) => {
      e.preventDefault();

      const btn = waBtn.querySelector('.wa-btn') as HTMLElement;
      const icon = waBtn.querySelector('.wa-icon') as SVGElement;
      const pulse = waBtn.querySelector('.wa-pulse') as HTMLElement;

      // Stop idle animation
      if (pulse) pulse.style.animationPlayState = 'paused';

      // Bounce animation
      gsap.timeline({
        onComplete: () => {
          // Navigate to WhatsApp after animation
          window.open(waBtn.getAttribute('href') || '#', '_blank');
        }
      })
      .to(btn, {
        scale: 0.9,
        duration: 0.1,
        ease: 'power2.in'
      })
      .to(btn, {
        scale: 1.1,
        duration: 0.15,
        ease: 'power2.out'
      })
      .to(btn, {
        scale: 1,
        duration: 0.1,
        ease: 'power1.inOut'
      });

      // Icon rotation
      gsap.to(icon, {
        rotation: 15,
        duration: 0.15,
        ease: 'power2.out'
      })
      .to(icon, {
        rotation: -10,
        duration: 0.15,
        ease: 'power2.inOut'
      })
      .to(icon, {
        rotation: 0,
        duration: 0.1,
        ease: 'power1.inOut'
      });

      // Ripple effect
      const ripple = waBtn.querySelector('.wa-ripple') as HTMLElement;
      if (ripple) {
        ripple.style.animation = 'none';
        ripple.offsetHeight; // Trigger reflow
        ripple.style.animation = 'wa-ripple 0.4s ease-out';
      }
    });
  } else if (waBtn && prefersReducedMotion.matches) {
    // Simple click for reduced motion - just navigate
    waBtn.addEventListener('click', (e) => {
      // Let the default behavior happen (open in new tab)
    });
  }
</script>

<style>
  .wa-float {
    position: fixed;
    bottom: 1.5rem;
    right: 1.5rem;
    z-index: 9998;
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    padding-bottom: env(safe-area-inset-bottom, 0);
  }

  .wa-pulse {
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    left: 0;
    border-radius: 50%;
    background-color: var(--color-sage);
    opacity: 0;
    animation: wa-pulse 2.5s ease-out infinite;
  }

  .wa-btn {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 3.75rem;
    height: 3.75rem;
    border-radius: 50%;
    background-color: var(--color-sage);
    box-shadow: 0 4px 20px rgba(124, 139, 111, 0.4);
    transition: all 0.25s ease;
    cursor: pointer;
  }

  .wa-btn:hover {
    background-color: var(--color-sage-dark);
    transform: scale(1.05);
    box-shadow: 0 6px 25px rgba(124, 139, 111, 0.5);
  }

  .wa-icon {
    width: 1.75rem;
    height: 1.75rem;
    color: white;
  }

  .wa-ripple {
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    left: 0;
    border-radius: 50%;
    border: 2px solid var(--color-sage);
    opacity: 0;
    pointer-events: none;
  }

  /* Pulse animation */
  @keyframes wa-pulse {
    0% {
      transform: scale(1);
      opacity: 0.5;
    }
    100% {
      transform: scale(1.5);
      opacity: 0;
    }
  }

  /* Ripple animation */
  @keyframes wa-ripple {
    0% {
      transform: scale(1);
      opacity: 0.6;
    }
    100% {
      transform: scale(1.8);
      opacity: 0;
    }
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .wa-pulse {
      animation: none;
    }

    .wa-ripple {
      animation: none;
    }

    .wa-btn:hover {
      transform: none;
    }
  }

  /* Mobile adjustments */
  @media (max-width: 640px) {
    .wa-float {
      bottom: 1rem;
      right: 1rem;
    }

    .wa-btn {
      width: 3.25rem;
      height: 3.25rem;
    }

    .wa-icon {
      width: 1.5rem;
      height: 1.5rem;
    }
  }
</style>
