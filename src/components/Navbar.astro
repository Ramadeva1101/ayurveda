---
const navItems = [
  { label: 'Home', href: '/' },
  { label: 'Our Sanctuary', href: '/sanctuary' },
  { label: 'Ayurveda Therapy', href: '/program' },
  { label: 'Wellness Programs', href: '/packages' },
  { label: 'About', href: '/about' },
  { label: 'Testimonials', href: '/testimonials' },
  { label: 'Contact', href: '/contact' },
];

const currentPath = Astro.url.pathname;
const isHome = currentPath === '/';
---

<header id="navbar" class:list={['navbar', { 'navbar--home': isHome }]}>
  <div class="navbar-container">
    <div class="container">
      <div class="navbar-inner">
        <!-- Logo -->
        <a href="/" class="navbar-logo" aria-label="Ayurvedic Wellness House - Home">
          <img
            id="navbar-logo"
            src={isHome ? "/images/logo-home.png" : "/images/logo.png"}
            alt="Ayurvedic Wellness House"
            class="navbar-logo-img"
            onerror="this.onerror=null; this.src='/images/logo.svg';"
          />
        </a>

        <!-- Desktop Navigation -->
        <nav class="navbar-nav" aria-label="Main navigation">
          <ul class="navbar-menu">
            {navItems.map((item) => (
              <li>
                <a
                  href={item.href}
                  class:list={[
                    'navbar-link',
                    { active: currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href)) }
                  ]}
                >
                  {item.label}
                </a>
              </li>
            ))}
          </ul>
        </nav>

        <!-- Mobile Menu Button -->
        <button
          type="button"
          id="mobile-menu-toggle"
          class="navbar-toggle"
          aria-controls="mobile-menu"
          aria-expanded="false"
          aria-label="Open menu"
        >
          <span class="hamburger-line"></span>
          <span class="hamburger-line"></span>
          <span class="hamburger-line"></span>
        </button>
      </div>
    </div>

    <!-- Mobile Menu -->
    <nav id="mobile-menu" class="mobile-menu" aria-label="Mobile navigation">
      <div class="container">
        <ul class="mobile-nav-list">
          {navItems.map((item) => (
            <li>
              <a
                href={item.href}
                class:list={[
                  'mobile-nav-link',
                  { active: currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href)) }
                ]}
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </nav>
  </div>
</header>

<script>
  function initNavbar() {
    const navbar = document.getElementById('navbar');
    const logo = document.getElementById('navbar-logo') as HTMLImageElement | null;
    const toggle = document.getElementById('mobile-menu-toggle');
    const mobileMenu = document.getElementById('mobile-menu');

    if (!navbar || !toggle || !mobileMenu) return;

    const isHomePage = navbar.classList.contains('navbar--home');
    let isMenuOpen = false;

    function handleScroll() {
      if (isHomePage) {
        if (window.scrollY > 50) {
          navbar.classList.add('scrolled');
          if (logo) logo.src = '/images/logo.png';
        } else {
          navbar.classList.remove('scrolled');
          if (logo) logo.src = '/images/logo-home.png';
        }
      }
    }

    function toggleMenu() {
      isMenuOpen = !isMenuOpen;
      toggle.classList.toggle('is-open', isMenuOpen);
      toggle.setAttribute('aria-expanded', String(isMenuOpen));
      mobileMenu.classList.toggle('is-open', isMenuOpen);
      document.body.classList.toggle('menu-open', isMenuOpen);
    }

    function closeMenu() {
      isMenuOpen = false;
      toggle.classList.remove('is-open');
      toggle.setAttribute('aria-expanded', 'false');
      mobileMenu.classList.remove('is-open');
      document.body.classList.remove('menu-open');
    }

    toggle.addEventListener('click', toggleMenu);
    mobileMenu.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', closeMenu);
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && isMenuOpen) closeMenu();
    });
    window.addEventListener('resize', () => {
      if (window.innerWidth >= 1024 && isMenuOpen) closeMenu();
    });
    window.addEventListener('scroll', handleScroll, { passive: true });
    handleScroll();
  }

  document.addEventListener('DOMContentLoaded', initNavbar);
</script>

<style>
  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    transition: background-color 0.3s ease, box-shadow 0.3s ease, padding 0.3s ease;
  }

  .navbar--home:not(.scrolled) {
    background-color: transparent;
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
  }

  .navbar.scrolled,
  .navbar:not(.navbar--home) {
    background-color: rgba(250, 246, 240, 0.97);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    box-shadow: 0 2px 16px rgba(63, 74, 50, 0.1);
  }

  .navbar-container {
    width: 100%;
  }

  .navbar-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 0;
    min-height: 5rem;
    transition: padding 0.3s ease;
  }

  .navbar.scrolled .navbar-inner,
  .navbar:not(.navbar--home) .navbar-inner {
    padding: 0.625rem 0;
  }

  .navbar-logo {
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }

  .navbar-logo-img {
    height: 2.5rem;
    width: auto;
    transition: height 0.3s ease;
  }

  .navbar.scrolled .navbar-logo-img,
  .navbar:not(.navbar--home) .navbar-logo-img {
    height: 2.25rem;
  }

  .navbar-nav {
    display: none;
  }

  @media (min-width: 1024px) {
    .navbar-nav {
      display: block;
    }
  }

  .navbar-menu {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .navbar-link {
    position: relative;
    font-family: 'Karla', sans-serif;
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: rgba(250, 246, 240, 0.85);
    padding: 0.375rem 0;
    transition: color 0.2s ease;
    text-decoration: none;
  }

  .navbar-link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 2px;
    background-color: var(--color-gold);
    transition: width 0.3s ease;
  }

  .navbar-link:hover::after,
  .navbar-link.active::after {
    width: 100%;
  }

  .navbar-link:hover,
  .navbar-link.active {
    color: var(--color-cream-base);
  }

  .navbar.scrolled .navbar-link,
  .navbar:not(.navbar--home) .navbar-link {
    color: var(--color-olive);
  }

  .navbar.scrolled .navbar-link:hover,
  .navbar.scrolled .navbar-link.active,
  .navbar:not(.navbar--home) .navbar-link:hover,
  .navbar:not(.navbar--home) .navbar-link.active {
    color: var(--color-sage);
  }

  .navbar-toggle {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    width: 2.5rem;
    height: 2.5rem;
    gap: 0.375rem;
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 0.375rem;
    border-radius: 0.25rem;
    transition: background-color 0.2s ease;
  }

  @media (min-width: 1024px) {
    .navbar-toggle {
      display: none;
    }
  }

  .hamburger-line {
    display: block;
    width: 1.375rem;
    height: 0.125rem;
    background-color: var(--color-cream-base);
    border-radius: 2px;
    transition: all 0.3s ease;
    transform-origin: center;
  }

  .navbar.scrolled .hamburger-line,
  .navbar:not(.navbar--home) .hamburger-line {
    background-color: var(--color-olive);
  }

  .navbar-toggle.is-open .hamburger-line:nth-child(1) {
    transform: translateY(0.5rem) rotate(45deg);
  }

  .navbar-toggle.is-open .hamburger-line:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }

  .navbar-toggle.is-open .hamburger-line:nth-child(3) {
    transform: translateY(-0.5rem) rotate(-45deg);
  }

  .mobile-menu {
    display: none;
    overflow: hidden;
    max-height: 0;
    transition: max-height 0.35s ease, background-color 0.3s ease;
  }

  .mobile-menu.is-open {
    display: block;
    max-height: 400px;
  }

  .navbar--home:not(.scrolled) .mobile-menu {
    background-color: rgba(20, 25, 15, 0.97);
    border-top: 1px solid rgba(250, 246, 240, 0.1);
  }

  .navbar.scrolled .mobile-menu,
  .navbar:not(.navbar--home) .mobile-menu {
    background-color: rgba(250, 246, 240, 0.98);
    border-top: 1px solid var(--color-cream-deep);
  }

  .mobile-nav-list {
    list-style: none;
    margin: 0;
    padding: 0.5rem 0 1rem;
  }

  .mobile-nav-link {
    display: block;
    padding: 0.875rem 0.75rem;
    font-family: 'Karla', sans-serif;
    font-size: 1rem;
    font-weight: 500;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    color: rgba(250, 246, 240, 0.85);
    border-bottom: 1px solid rgba(250, 246, 240, 0.08);
    transition: all 0.2s ease;
    text-decoration: none;
  }

  .mobile-nav-link:hover,
  .mobile-nav-link.active {
    color: var(--color-cream-base);
    background-color: rgba(250, 246, 240, 0.08);
    padding-left: 1.25rem;
  }

  .navbar.scrolled .mobile-nav-link,
  .navbar:not(.navbar--home) .mobile-nav-link {
    color: var(--color-olive);
    border-bottom-color: var(--color-cream-deep);
  }

  .navbar.scrolled .mobile-nav-link:hover,
  .navbar.scrolled .mobile-nav-link.active,
  .navbar:not(.navbar--home) .mobile-nav-link:hover,
  .navbar:not(.navbar--home) .mobile-nav-link.active {
    color: var(--color-sage);
    background-color: rgba(63, 74, 50, 0.05);
    padding-left: 1.25rem;
  }

  :global(body.menu-open) {
    overflow: hidden;
  }
</style>
