---
const navItems = [
  { label: 'Home', href: '/' },
  { label: 'About', href: '/about' },
  { label: 'Program', href: '/program' },
  { label: 'Packages', href: '/packages' },
  { label: 'Contact', href: '/contact' },
];

const currentPath = Astro.url.pathname;
const isHome = currentPath === '/';
---

<header
  id="navbar"
  class:list={['navbar', { 'navbar--home': isHome }]}
  x-data="{ open: false }"
>
  <nav class="navbar-container">
    <div class="container">
      <div class="navbar-inner">
        <!-- Logo -->
        <a href="/" class="navbar-logo" aria-label="Ayurvedic Wellness House - Home">
          <img
            id="navbar-logo"
            src={isHome ? "/images/logo-home.png" : "/images/logo.png"}
            alt="Ayurvedic Wellness House"
            class="navbar-logo-img"
            onerror="this.onerror=null; this.src='/images/logo.svg';"
          />
        </a>

        <!-- Desktop Navigation -->
        <ul class="navbar-menu">
          {navItems.map((item) => (
            <li>
              <a
                href={item.href}
                class:list={[
                  'navbar-link',
                  { active: currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href)) }
                ]}
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>

        <!-- Mobile Menu Button -->
        <button
          type="button"
          class="navbar-toggle"
          @click="open = !open"
          :aria-expanded="open"
          aria-controls="mobile-menu"
          aria-label="Open menu"
        >
          <span class="hamburger-line" :class="{ 'rotate': open }"></span>
          <span class="hamburger-line" :class="{ 'opacity-0': open }"></span>
          <span class="hamburger-line" :class="{ 'rotate-reverse': open }"></span>
        </button>
      </div>
    </div>

    <!-- Mobile Menu -->
    <div
      id="mobile-menu"
      class="mobile-menu"
      x-show="open"
      x-transition:enter="transition ease-out duration-200"
      x-transition:enter-start="opacity-0 -translate-y-2"
      x-transition:enter-end="opacity-100 translate-y-0"
      x-transition:leave="transition ease-in duration-150"
      x-transition:leave-start="opacity-100 translate-y-0"
      x-transition:leave-end="opacity-0 -translate-y-2"
      @click.outside="open = false"
    >
      <ul class="container">
        {navItems.map((item) => (
          <li>
            <a
              href={item.href}
              class:list={[
                'mobile-nav-link',
                { active: currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href)) }
              ]}
              @click="open = false"
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </nav>
</header>

<script>
  function initNavbar() {
    const navbar = document.getElementById('navbar');
    const logo = document.getElementById('navbar-logo');
    if (!navbar) return;

    const isHomePage = navbar.classList.contains('navbar--home');

    const handleScroll = () => {
      if (isHomePage) {
        if (window.scrollY > 50) {
          navbar.classList.add('scrolled');
          if (logo) {
            logo.src = '/images/logo.png';
          }
        } else {
          navbar.classList.remove('scrolled');
          if (logo) {
            logo.src = '/images/logo-home.png';
          }
        }
      }
    };

    window.addEventListener('scroll', handleScroll, { passive: true });
    handleScroll();
  }

  document.addEventListener('DOMContentLoaded', initNavbar);
</script>

<style>
  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
    transition: background-color 0.4s ease, box-shadow 0.4s ease;
  }

  /* Home page at top: fully transparent, text on hero */
  .navbar--home:not(.scrolled) {
    background-color: transparent;
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
  }

  /* Home page scrolled OR other pages at top: cream bg + dark text */
  .navbar.scrolled,
  .navbar:not(.navbar--home) {
    background-color: rgba(250, 246, 240, 0.96);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    box-shadow: 0 2px 20px rgba(63, 74, 50, 0.12);
  }

  .navbar-container {
    width: 100%;
  }

  .navbar-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 0;
    min-height: 5rem;
    transition: padding 0.3s ease;
  }

  .navbar.scrolled .navbar-inner,
  .navbar:not(.navbar--home) .navbar-inner {
    padding: 0.5rem 0;
  }

  .navbar-logo {
    display: flex;
    align-items: center;
  }

  .navbar-logo-img {
    height: 3rem;
    width: auto;
    transition: all 0.3s ease;
  }

  .navbar-menu {
    display: none;
    align-items: center;
    gap: 2rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  @media (min-width: 768px) {
    .navbar-menu {
      display: flex;
    }
  }

  /* Default (home page, top of page): cream text on dark hero */
  .navbar-link {
    position: relative;
    font-family: 'Karla', sans-serif;
    font-size: 0.875rem;
    font-weight: 500;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    color: rgba(250, 246, 240, 0.8);
    padding: 0.5rem 0;
    transition: color 0.2s ease;
  }

  .navbar-link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 2px;
    background-color: var(--color-gold);
    transition: width 0.3s ease;
  }

  .navbar-link:hover::after,
  .navbar-link.active::after {
    width: 100%;
  }

  .navbar-link:hover,
  .navbar-link.active {
    color: var(--color-cream-base);
  }

  /* Scrolled home page OR other pages: dark text on cream bg */
  .navbar.scrolled .navbar-link,
  .navbar:not(.navbar--home) .navbar-link {
    color: var(--color-olive);
  }

  .navbar.scrolled .navbar-link:hover,
  .navbar.scrolled .navbar-link.active,
  .navbar:not(.navbar--home) .navbar-link:hover,
  .navbar:not(.navbar--home) .navbar-link.active {
    color: var(--color-sage);
  }

  .navbar-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    width: 2.5rem;
    height: 2.5rem;
    gap: 0.375rem;
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 0;
  }

  @media (max-width: 767px) {
    .navbar-toggle {
      display: flex;
    }
  }

  /* Default: cream hamburger on hero */
  .hamburger-line {
    display: block;
    width: 1.5rem;
    height: 0.125rem;
    background-color: var(--color-cream-base);
    transition: all 0.3s ease;
    transform-origin: center;
  }

  /* Scrolled or other pages: dark hamburger */
  .navbar.scrolled .hamburger-line,
  .navbar:not(.navbar--home) .hamburger-line {
    background-color: var(--color-olive);
  }

  .hamburger-line.rotate {
    transform: rotate(45deg) translateY(0.25rem);
  }

  .hamburger-line.rotate-reverse {
    transform: rotate(-45deg) translateY(-0.25rem);
  }

  .hamburger-line.opacity-0 {
    opacity: 0;
  }

  .mobile-menu {
    display: none;
  }

  /* Default mobile menu on hero (home page top) */
  .navbar--home:not(.scrolled) .mobile-menu {
    background-color: rgba(20, 25, 15, 0.95);
    border-top: 1px solid rgba(250, 246, 240, 0.1);
  }

  /* Scrolled or other pages: cream mobile menu */
  .navbar.scrolled .mobile-menu,
  .navbar:not(.navbar--home) .mobile-menu {
    background-color: rgba(250, 246, 240, 0.98);
    border-top: 1px solid var(--color-cream-deep);
  }

  .mobile-menu[x-show] {
    display: block;
  }

  .mobile-menu ul {
    display: flex;
    flex-direction: column;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  /* Default: cream text on hero */
  .mobile-nav-link {
    display: block;
    padding: 1rem;
    font-family: 'Karla', sans-serif;
    font-size: 1rem;
    font-weight: 500;
    letter-spacing: 0.025em;
    color: rgba(250, 246, 240, 0.8);
    border-bottom: 1px solid rgba(250, 246, 240, 0.08);
    transition: all 0.2s ease;
  }

  .mobile-nav-link:hover,
  .mobile-nav-link.active {
    background-color: rgba(250, 246, 240, 0.1);
    color: var(--color-cream-base);
    padding-left: 1.5rem;
  }

  /* Scrolled or other pages: dark text on cream */
  .navbar.scrolled .mobile-nav-link,
  .navbar:not(.navbar--home) .mobile-nav-link {
    color: var(--color-olive);
    border-bottom-color: var(--color-cream-deep);
  }

  .navbar.scrolled .mobile-nav-link:hover,
  .navbar.scrolled .mobile-nav-link.active,
  .navbar:not(.navbar--home) .mobile-nav-link:hover,
  .navbar:not(.navbar--home) .mobile-nav-link.active {
    background-color: rgba(63, 74, 50, 0.06);
    color: var(--color-sage);
    padding-left: 1.5rem;
  }
</style>
