---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = 'Authentic Ayurvedic treatment led by Dr. Komang Sudarmi, BAMS., MS., PhD (Ayurveda). Combining traditional Indian Ayurveda with Indonesian healing wisdom.',
  ogImage = '/images/og-default.jpg'
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? 'https://ayurvedicwellnesshouse.com');

// Title logic: home page gets the tagline directly, inner pages get "Page | Brand"
const pageTitle = title === 'Ayurvedic Wellness House'
  ? 'Ayurvedic Wellness House'
  : `${title} | Ayurvedic Wellness House`;
const ogTitle = title === 'Ayurvedic Wellness House'
  ? 'Ayurvedic Wellness House — Heal With The Ancient Wisdom'
  : `${title} | Ayurvedic Wellness House — Heal With The Ancient Wisdom`;

// JSON-LD Structured Data — HealthAndBeautyBusiness
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'HealthAndBeautyBusiness',
  name: 'Ayurvedic Wellness House',
  description: 'Authentic Ayurvedic treatment led by Dr. Komang Sudarmi, BAMS., MS., PhD (Ayurveda). Combining traditional Indian Ayurveda with Indonesian healing wisdom.',
  // TODO: replace with the client's real address
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Bali',
    addressCountry: 'ID'
  },
  // TODO: replace with the client's real operating hours
  openingHours: ['Mo-Sa 09:00-17:00'],
  // TODO: replace with the client's real contact
  telephone: '+62 859-2646-1359',
  url: 'https://ayurvedicwellnesshouse.com',
  // TODO: add Instagram URL
  sameAs: ['https://instagram.com/ayurvedicwellnesshouse'],
  priceRange: '$$'
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary Meta Tags -->
    <title>{pageTitle}</title>
    <meta name="title" content={ogTitle} />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="Ayurvedic Wellness House" />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={ogTitle} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={ogImage} />

    <!-- Sitemap -->
    <link rel="sitemap" href="/sitemap-index.xml" />
  </head>
  <body>
    <!-- Skip to Content -->
    <a href="#main-content" class="skip-link">Skip to main content</a>

    <slot />

    <!-- GSAP Animation Script -->
    <script>
      import gsap from 'gsap';
      import { ScrollTrigger } from 'gsap/ScrollTrigger';

      gsap.registerPlugin(ScrollTrigger);

      // Make GSAP available globally for components
      (window as any).gsap = gsap;
      (window as any).ScrollTrigger = ScrollTrigger;
    </script>

    <!-- Main JS -->
    <script src="../scripts/main.js"></script>
  </body>
</html>
